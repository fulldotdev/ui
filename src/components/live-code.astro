---
import Check from "@lucide/astro/icons/check"
import Copy from "@lucide/astro/icons/copy"

import { Button } from "@/components/ui/button"
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs"

type ComponentProps = {
  name?: string
}

type Props = {
  filename?: string
  lang?: string
  componentProps?: ComponentProps
}

const { componentProps = {} }: Props = Astro.props
const componentSlug = componentProps.name
  ?.trim()
  .replace(/([a-z0-9])([A-Z])/g, "$1-$2")
  .replace(/[\s_]+/g, "-")
  .replace(/[^a-zA-Z0-9-]/g, "")
  .replace(/-+/g, "-")
  .toLowerCase()
const isBlockPreview = Boolean(
  componentSlug?.match(
    /^(article|articles|banner|contact|content|cta|faqs|features|footer|header|hero|logos|pricing|product|products|reviews|services)-\d+$/
  )
)
const installCommand = componentSlug
  ? `npx shadcn@latest add @fulldev/${componentSlug}`
  : undefined
const installButtonId = installCommand
  ? `live-code-copy-install-${crypto.randomUUID()}`
  : undefined
---

<Tabs defaultValue="preview" class="live-code-layout w-full gap-3">
  <div
    class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
  >
    <TabsList class="justify-start self-start">
      <TabsTrigger value="preview" class="flex-none"> Preview </TabsTrigger>
      <TabsTrigger value="code" class="flex-none">Code</TabsTrigger>
    </TabsList>

    <div
      class="flex min-w-0 flex-col gap-3 sm:max-w-xl sm:flex-1 sm:flex-row sm:items-center sm:justify-end sm:gap-6"
    >
      {
        installCommand && (
          <Button
            id={installButtonId}
            type="button"
            variant="outline"
            size="sm"
            class="max-w-full shrink-0 self-start font-mono text-xs sm:self-center sm:whitespace-nowrap"
            data-source={installCommand}
            aria-label={`Copy install command: ${installCommand}`}
          >
            <Copy class="live-code-copy-icon size-4" />
            <Check class="live-code-check-icon hidden size-4" />
            <span>{installCommand}</span>
          </Button>
        )
      }
    </div>
  </div>

  <TabsContent value="preview" class="mt-0 w-full">
    <div
      class:list={[
        "border-border bg-background w-full overflow-hidden border",
        isBlockPreview
          ? "rounded-lg"
          : "flex min-h-64 items-center justify-center rounded-xl p-10",
      ]}
    >
      <div
        class:list={[
          isBlockPreview
            ? "bg-background w-full"
            : "flex w-full flex-wrap items-center justify-center gap-3",
        ]}
      >
        <slot name="example" />
      </div>
    </div>
  </TabsContent>

  <TabsContent value="code" class="mt-0 w-full" hidden>
    <div
      data-slot="live-code-panel"
      class="border-border bg-muted/60 [&_.live-code-source]:bg-background/40 w-full overflow-hidden rounded-xl border [&_.live-code-source]:rounded-lg [&_pre.astro-code]:m-0 [&_pre.astro-code]:rounded-none [&_pre.astro-code]:border-0 [&_pre.astro-code]:!bg-transparent [&_pre.astro-code]:p-4 dark:[&_pre.astro-code]:!text-[var(--shiki-dark,var(--foreground))] [&_pre.astro-code_code]:!text-[var(--shiki-light,var(--foreground))] dark:[&_pre.astro-code_code]:!text-[var(--shiki-dark,var(--foreground))] dark:[&_pre.astro-code_span[style*='--shiki-dark']]:[font-weight:var(--shiki-dark-font-weight,inherit)] dark:[&_pre.astro-code_span[style*='--shiki-dark']]:!text-[var(--shiki-dark)] dark:[&_pre.astro-code_span[style*='--shiki-dark']]:[font-style:var(--shiki-dark-font-style,inherit)] dark:[&_pre.astro-code_span[style*='--shiki-dark']]:[text-decoration:var(--shiki-dark-text-decoration,inherit)]"
    >
      <div class="relative">
        <Button
          type="button"
          variant="outline"
          size="icon-sm"
          class="absolute top-3 right-3 z-10"
          data-slot="live-code-copy-source"
          aria-label="Copy code example"
        >
          <Copy class="live-code-source-copy-icon size-4" />
          <Check class="live-code-source-check-icon hidden size-4" />
        </Button>

        <slot name="code" />
      </div>
    </div>
  </TabsContent>
</Tabs>

<script is:inline define:vars={{ installButtonId }}>
  const button = installButtonId
    ? document.getElementById(installButtonId)
    : null

  if (button instanceof HTMLButtonElement) {
    button.addEventListener("click", async () => {
      const source = button.dataset.source

      if (!source) return

      try {
        await navigator.clipboard.writeText(source)
        button.querySelector(".live-code-copy-icon")?.classList.add("hidden")
        button
          .querySelector(".live-code-check-icon")
          ?.classList.remove("hidden")

        window.setTimeout(() => {
          button
            .querySelector(".live-code-copy-icon")
            ?.classList.remove("hidden")
          button.querySelector(".live-code-check-icon")?.classList.add("hidden")
        }, 1200)
      } catch {
        // Ignore clipboard failures; the button remains available for retry.
      }
    })
  }

  if (!window["__fulldevLiveCodeInitialized"]) {
    window["__fulldevLiveCodeInitialized"] = true

    document.addEventListener("click", async (event) => {
      const target = event.target

      if (!(target instanceof Element)) return

      const codeButton = target.closest("[data-slot='live-code-copy-source']")
      if (!(codeButton instanceof HTMLButtonElement)) return

      const codePanel = codeButton.closest("[data-slot='live-code-panel']")
      if (!(codePanel instanceof HTMLElement)) return

      const codeElement =
        codePanel.querySelector("pre code") ?? codePanel.querySelector("pre")
      const source = codeElement?.textContent?.replace(/\n$/, "")

      if (!source) return

      try {
        await navigator.clipboard.writeText(source)
        codeButton
          .querySelector(".live-code-source-copy-icon")
          ?.classList.add("hidden")
        codeButton
          .querySelector(".live-code-source-check-icon")
          ?.classList.remove("hidden")

        window.setTimeout(() => {
          codeButton
            .querySelector(".live-code-source-copy-icon")
            ?.classList.remove("hidden")
          codeButton
            .querySelector(".live-code-source-check-icon")
            ?.classList.add("hidden")
        }, 1200)
      } catch {
        // Ignore clipboard failures; the button remains available for retry.
      }
    })
  }
</script>
