---
import SearchIcon from "@lucide/astro/icons/search"

import { cn } from "@/lib/utils"
import {
  Command,
  CommandDialog,
  CommandEmpty,
  CommandGroup,
  CommandInput,
  CommandItem,
  CommandList,
  CommandShortcut,
} from "@/components/ui/command"
import { Dialog, DialogTrigger } from "@/components/ui/dialog"

type Props = {
  links: {
    text: string
    href: string
    keywords?: string[]
    links?: {
      text: string
      href: string
      keywords?: string[]
    }[]
  }[]
  size?: "default" | "compact"
  class?: string
}

const { links, size = "default", class: className } = Astro.props
---

<Dialog>
  <DialogTrigger
    variant="ghost"
    size="sm"
    class={cn(
      "border-input bg-background text-muted-foreground hover:bg-background hover:text-foreground h-9 w-full justify-start rounded-md px-2.5",
      size === "compact" && "w-48",
      className
    )}
  >
    <SearchIcon data-icon="inline-start" />
    <span class="truncate">Search</span>
  </DialogTrigger>

  <CommandDialog
    title="Search pages"
    description="Search the site and jump to a page."
  >
    <Command>
      <CommandInput placeholder="Search pages..." />
      <CommandList>
        <CommandEmpty>No results found.</CommandEmpty>

        {
          links.map((group) => (
            <CommandGroup heading={group.text}>
              {(group.links ?? [group]).map((item) => (
                <CommandItem
                  href={item.href}
                  value={item.href}
                  label={item.text}
                  keywords={item.keywords}
                >
                  {item.text}
                  <CommandShortcut>{item.href}</CommandShortcut>
                </CommandItem>
              ))}
            </CommandGroup>
          ))
        }
      </CommandList>
    </Command>
  </CommandDialog>
</Dialog>
