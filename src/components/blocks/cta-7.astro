---
import { Avatar, AvatarFallback, AvatarGroup } from "@/components/ui/avatar"
import { Button } from "@/components/ui/button"
import { Rating } from "@/components/ui/rating"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  title: string
  description: string
  actions?: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
  socialProof?: {
    avatars: string[]
    rating: number
    text: string
  }
}

const { title, description, actions, socialProof } = Astro.props
---

<Section class="bg-accent/50">
  <SectionContainer class="items-center text-center">
    <div class="flex max-w-2xl flex-col items-center gap-5">
      <h2
        class="text-foreground text-3xl leading-[1.1] font-semibold tracking-tight text-balance sm:text-4xl"
      >
        {title}
      </h2>
      <p class="text-muted-foreground text-lg leading-relaxed text-balance">
        {description}
      </p>
    </div>
    {
      actions?.length ? (
        <div class="flex flex-wrap justify-center gap-3">
          {actions.map((action, i) => (
            <Button
              as="a"
              href={action.href}
              size="lg"
              variant={action.variant ?? (i === 0 ? "default" : "secondary")}
            >
              {action.label}
            </Button>
          ))}
        </div>
      ) : null
    }
    {
      socialProof ? (
        <div class="flex flex-col items-center gap-3">
          <AvatarGroup>
            {socialProof.avatars.map((initials) => (
              <Avatar class="ring-accent size-11 ring">
                <AvatarFallback>{initials}</AvatarFallback>
              </Avatar>
            ))}
          </AvatarGroup>
          <div class="flex items-center gap-2">
            <Rating value={socialProof.rating} />
            <span class="text-muted-foreground text-sm">
              {socialProof.text}
            </span>
          </div>
        </div>
      ) : null
    }
  </SectionContainer>
</Section>
