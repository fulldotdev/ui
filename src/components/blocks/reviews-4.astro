---
import type { ImageMetadata } from "astro"

import { cn } from "@/lib/utils"
import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar"
import { Card, CardContent } from "@/components/ui/card"
import { Marquee } from "@/components/ui/marquee"
import { Rating } from "@/components/ui/rating"
import { Section, SectionContainer } from "@/components/ui/section"

type Props = {
  class?: string
  title?: string
  description?: string
  reviews: {
    rating: number
    quote: string
    image?: ImageMetadata
    initials: string
    name: string
    role: string
  }[]
}

const { class: className, title, description, reviews } = Astro.props

const half = Math.ceil(reviews.length / 2)
const topRow = reviews.slice(0, half)
const bottomRow = reviews.slice(half)
---

<Section class={cn("", className)}>
  {
    (title || description) && (
      <SectionContainer class="items-center gap-4 text-center">
        {title && (
          <h2 class="text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl">
            {title}
          </h2>
        )}
        {description && (
          <p class="text-muted-foreground max-w-2xl text-lg leading-relaxed text-balance">
            {description}
          </p>
        )}
      </SectionContainer>
    )
  }
  <div class="flex flex-col gap-6 overflow-x-hidden py-1">
    <Marquee
      direction="left"
      pauseOnHover
      infinite
      gap="1rem"
      class="py-1 [&>div]:items-stretch"
    >
      {
        topRow.map((item) => (
          <Card class="flex w-[22rem] shrink-0 self-stretch">
            <CardContent class="flex min-w-0 flex-1 flex-col gap-3">
              <Rating value={item.rating} />
              <p class="text-muted-foreground min-w-0 text-sm leading-relaxed">
                {item.quote}
              </p>
              <div class="mt-auto flex items-center gap-3 pt-1">
                <Avatar>
                  <AvatarImage src={item.image} alt={item.name} />
                  <AvatarFallback>{item.initials}</AvatarFallback>
                </Avatar>
                <div>
                  <p class="text-foreground text-sm font-medium">{item.name}</p>
                  <p class="text-muted-foreground text-xs">{item.role}</p>
                </div>
              </div>
            </CardContent>
          </Card>
        ))
      }
    </Marquee>
    <Marquee
      direction="right"
      pauseOnHover
      infinite
      gap="1rem"
      class="py-1 [&>div]:items-stretch"
    >
      {
        bottomRow.map((item) => (
          <Card class="flex w-[22rem] shrink-0 self-stretch">
            <CardContent class="flex min-w-0 flex-1 flex-col gap-3">
              <Rating value={item.rating} />
              <p class="text-muted-foreground min-w-0 text-sm leading-relaxed">
                {item.quote}
              </p>
              <div class="mt-auto flex items-center gap-3 pt-1">
                <Avatar>
                  <AvatarImage src={item.image} alt={item.name} />
                  <AvatarFallback>{item.initials}</AvatarFallback>
                </Avatar>
                <div>
                  <p class="text-foreground text-sm font-medium">{item.name}</p>
                  <p class="text-muted-foreground text-xs">{item.role}</p>
                </div>
              </div>
            </CardContent>
          </Card>
        ))
      }
    </Marquee>
  </div>
</Section>
