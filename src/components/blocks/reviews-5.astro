---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Rating } from "@/components/ui/rating"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    summary: {
      title: string
      rating: number
    }
    items: {
      title: string
      description: string
    }[]
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="grid gap-8 lg:grid-cols-[18rem_minmax(0,1fr)] lg:items-start">
    <Card>
      <CardHeader><CardTitle>{props.summary.title}</CardTitle></CardHeader>
      <CardContent><Rating value={props.summary.rating} /></CardContent>
    </Card>
    <div class="grid gap-3">
      {props.items.map((item) => (
        <Card>
          <CardContent class="grid gap-3 p-5 md:grid-cols-[12rem_minmax(0,1fr)]">
            <p class="font-medium">{item.title}</p>
            <p class="text-muted-foreground text-sm leading-6">{item.description}</p>
          </CardContent>
        </Card>
      ))}
    </div>
  </SectionContent>
</Section>
