---
import PlaceholderImage from "@/assets/placeholder.webp"
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { Avatar, AvatarFallback, AvatarGroup } from "@/components/ui/avatar"
import { Button } from "@/components/ui/button"
import { Rating } from "@/components/ui/rating"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  title: string
  description: string
  actions?: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
  socialProof?: {
    avatars: string[]
    rating: number
    text: string
  }
  image?: {
    src: ImageMetadata
    alt: string
  }
}

const {
  title,
  description,
  actions,
  socialProof,
  image = { src: PlaceholderImage, alt: "CTA image" },
} = Astro.props
---

<Section variant="floating" class="dark bg-background overflow-hidden">
  <Image
    src={image.src}
    alt={image.alt}
    class="absolute inset-0 size-full object-cover opacity-50"
    widths={[640, 960, 1280, 1536]}
    sizes="(min-width: 80rem) 80rem, 100vw"
  />
  <SectionContainer class="items-center text-center">
    <div class="flex max-w-2xl flex-col items-center gap-5">
      <h2
        class="text-foreground text-3xl leading-[1.1] font-semibold tracking-tight text-balance sm:text-4xl"
      >
        {title}
      </h2>
      <p class="text-muted-foreground text-lg leading-relaxed text-balance">
        {description}
      </p>
    </div>
    {
      actions?.length ? (
        <div class="flex flex-wrap justify-center gap-3">
          {actions.map((action, i) => (
            <Button
              as="a"
              href={action.href}
              size="lg"
              variant={action.variant ?? (i === 0 ? "default" : "outline")}
            >
              {action.label}
            </Button>
          ))}
        </div>
      ) : null
    }
    {
      socialProof ? (
        <div class="flex items-center gap-3">
          <AvatarGroup>
            {socialProof.avatars.map((initials) => (
              <Avatar class="ring-background size-11 ring">
                <AvatarFallback>{initials}</AvatarFallback>
              </Avatar>
            ))}
          </AvatarGroup>
          <div class="flex flex-col gap-0.5">
            <Rating value={socialProof.rating} />
            <span class="text-muted-foreground text-sm">
              {socialProof.text}
            </span>
          </div>
        </div>
      ) : null
    }
  </SectionContainer>
</Section>
