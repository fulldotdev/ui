---
import { Button } from "@/components/ui/button"
import { Section, SectionContent } from "@/components/ui/section"

type BlockAction = {
  label: string
  href: string
  variant?: "default" | "outline" | "ghost" | "secondary"
}

interface Props {
  props: {
    title: string
    description: string
    action: BlockAction
    note: string
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="rounded-3xl border p-8 sm:p-10">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_20rem] lg:items-start">
      <div>
        <h2 class="text-3xl font-semibold tracking-tight text-balance">{props.title}</h2>
        <p class="text-muted-foreground mt-4 text-base leading-7">{props.description}</p>
      </div>
      <div class="flex flex-col gap-3 lg:items-end">
        <Button as="a" href={props.action.href} variant={props.action.variant}>{props.action.label}</Button>
        <p class="text-muted-foreground text-sm">{props.note}</p>
      </div>
    </div>
  </SectionContent>
</Section>
