---
import type { ImageMetadata } from "astro"
import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import { Card, CardContent, CardDescription, CardFooter, CardHeader, CardTitle } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"
import BlockPlaceholder from "@/components/block-placeholder.astro"

type BlockAction = {
  label: string
  href: string
  variant?: "default" | "outline" | "ghost" | "secondary"
}

type BlockImage = {
  src: ImageMetadata
  alt: string
}

interface Props {
  props: {
    featured: {
      badge: string
      title: string
      description: string
      image: BlockImage
      action: BlockAction
    }
    stories: {
      image: BlockImage
      category: string
      title: string
      description: string
    }[]
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="grid gap-8 lg:grid-cols-[minmax(0,1.4fr)_minmax(0,1fr)]">
    <Card class="overflow-hidden">
      <BlockPlaceholder image={props.featured.image} class="aspect-[16/10] border-b" />
      <CardHeader class="gap-4">
        <Badge variant="outline" class="w-fit">{props.featured.badge}</Badge>
        <div>
          <CardTitle class="text-3xl leading-tight">{props.featured.title}</CardTitle>
          <CardDescription class="mt-3 max-w-2xl text-base leading-7">{props.featured.description}</CardDescription>
        </div>
      </CardHeader>
      <CardFooter>
        <Button as="a" href={props.featured.action.href} variant={props.featured.action.variant}>
          {props.featured.action.label}
        </Button>
      </CardFooter>
    </Card>

    <div class="flex flex-col gap-4">
      {props.stories.map((story) => (
        <Card>
          <CardContent class="flex gap-4 p-5">
            <BlockPlaceholder image={story.image} class="size-24 shrink-0 rounded-xl border" />
            <div class="flex flex-col gap-2">
              <Badge variant="secondary" class="w-fit">{story.category}</Badge>
              <h3 class="text-lg font-medium leading-snug">{story.title}</h3>
              <p class="text-muted-foreground text-sm leading-6">{story.description}</p>
            </div>
          </CardContent>
        </Card>
      ))}
    </div>
  </SectionContent>
</Section>
