---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { cn } from "@/lib/utils"
import { Button } from "@/components/ui/button"
import { Section, SectionContainer } from "@/components/ui/section"

type Props = {
  class?: string
  title: string
  description: string
  buttons: {
    label: string
    href: string
    variant?: "default" | "outline" | "secondary" | "ghost"
  }[]
  image: {
    src: ImageMetadata
    alt: string
  }
}

const { class: className, title, description, buttons, image } = Astro.props
---

<Section class={cn("gap-8 pt-8", className)}>
  <SectionContainer class="border-y py-8">
    <div
      class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between"
    >
      <h1
        class="text-foreground max-w-xl text-2xl leading-[1.2] font-semibold tracking-tight text-balance sm:text-3xl"
      >
        {title}
      </h1>
      <p
        class="text-muted-foreground max-w-md text-base leading-relaxed text-balance"
      >
        {description}
      </p>
      <div class="flex flex-wrap gap-3">
        {
          buttons.map(({ href, label, ...button }, index) => (
            <Button
              as="a"
              href={href}
              variant={
                button.variant ?? (index === 0 ? "default" : "secondary")
              }
              {...button}
            >
              {label}
            </Button>
          ))
        }
      </div>
    </div>
  </SectionContainer>
  <SectionContainer>
    <Image
      src={image.src}
      alt={image.alt}
      class="aspect-video w-full rounded-xl border object-cover"
      widths={[640, 960, 1280, 1536]}
      sizes="(min-width: 80rem) 80rem, 100vw"
      loading="eager"
    />
  </SectionContainer>
</Section>
