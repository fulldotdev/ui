---
import { Badge } from "@/components/ui/badge"
import { Card, CardContent } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    badge: string
    title: string
    cards: {
      title: string
      description: string
    }[]
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="gap-8">
    <div class="max-w-3xl">
      <Badge variant="secondary" class="w-fit">{props.badge}</Badge>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-balance sm:text-5xl">{props.title}</h1>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {props.cards.map((card) => (
        <Card>
          <CardContent class="flex h-full flex-col gap-3 p-6">
            <h3 class="text-xl font-medium">{card.title}</h3>
            <p class="text-muted-foreground text-sm leading-6">{card.description}</p>
          </CardContent>
        </Card>
      ))}
    </div>
  </SectionContent>
</Section>
