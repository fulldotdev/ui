---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { Button } from "@/components/ui/button"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  title: string
  description: string
  actions: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
  image: {
    src: ImageMetadata
    alt: string
  }
}

const { title, description, actions, image } = Astro.props
---

<Section class="gap-8 pt-8">
  <SectionContainer class="border-y py-8">
    <div
      class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between"
    >
      <h1
        class="text-foreground max-w-xl text-2xl leading-[1.2] font-semibold tracking-tight text-balance sm:text-3xl"
      >
        {title}
      </h1>
      <p
        class="text-muted-foreground max-w-md text-base leading-relaxed text-balance"
      >
        {description}
      </p>
      <div class="flex flex-wrap gap-3">
        {
          actions.map((action, i) => (
            <Button
              as="a"
              href={action.href}
              variant={action.variant ?? (i === 0 ? "default" : "secondary")}
            >
              {action.label}
            </Button>
          ))
        }
      </div>
    </div>
  </SectionContainer>
  <SectionContainer>
    <Image
      src={image.src}
      alt={image.alt}
      class="aspect-video w-full rounded-xl border object-cover"
      widths={[640, 960, 1280, 1536]}
      sizes="(min-width: 80rem) 80rem, 100vw"
      loading="eager"
    />
  </SectionContainer>
</Section>
