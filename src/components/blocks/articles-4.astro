---
import type { ImageMetadata } from "astro"
import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"
import BlockPlaceholder from "@/components/block-placeholder.astro"

type BlockAction = {
  label: string
  href: string
  variant?: "default" | "outline" | "ghost" | "secondary"
}

type BlockImage = {
  src: ImageMetadata
  alt: string
}

interface Props {
  props: {
    badge?: string
    description: string
    stories: {
      image: BlockImage
      title: string
    }[]
    aside?: {
      badge: string
      title: string
      description: string
      panelText: string
      action: BlockAction
    }
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent
    class="grid gap-8 xl:grid-cols-[minmax(0,1.6fr)_20rem] xl:items-start"
  >
    <div class="grid gap-4 md:grid-cols-2">
      {
        props.stories.map((story) => (
          <Card class="overflow-hidden">
            <BlockPlaceholder
              image={story.image}
              class="aspect-[16/10] border-b"
            />
            <CardHeader>
              <Badge variant="secondary" class="w-fit">
                {props.badge}
              </Badge>
              <CardTitle class="text-2xl leading-tight">
                {story.title}
              </CardTitle>
              <CardDescription>{props.description}</CardDescription>
            </CardHeader>
          </Card>
        ))
      }
    </div>

    {
      props.aside ? (
        <Card class="xl:sticky xl:top-24">
          <CardHeader>
            <Badge variant="outline" class="w-fit">
              {props.aside.badge}
            </Badge>
            <CardTitle>{props.aside.title}</CardTitle>
            <CardDescription>{props.aside.description}</CardDescription>
          </CardHeader>
          <CardContent class="flex flex-col gap-3">
            <div class="bg-muted/40 rounded-xl border p-4 text-sm leading-6">
              {props.aside.panelText}
            </div>
            <Button
              as="a"
              href={props.aside.action.href}
              variant={props.aside.action.variant}
            >
              {props.aside.action.label}
            </Button>
          </CardContent>
        </Card>
      ) : null
    }
  </SectionContent>
</Section>
