---
import { Badge } from "@/components/ui/badge"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    badge: string
    title: string
    items: {
      title: string
      description: string
    }[]
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="grid gap-8 lg:grid-cols-[20rem_minmax(0,1fr)] lg:items-start">
    <div class="max-w-sm">
      <Badge variant="outline">{props.badge}</Badge>
      <h2 class="mt-4 text-3xl font-semibold tracking-tight text-balance">{props.title}</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
      {props.items.map((service) => (
        <Card>
          <CardHeader><CardTitle class="text-lg">{service.title}</CardTitle></CardHeader>
          <CardContent class="text-muted-foreground text-sm leading-6">{service.description}</CardContent>
        </Card>
      ))}
    </div>
  </SectionContent>
</Section>
