---
import { Card, CardContent } from "@/components/ui/card"
import { Logo, LogoText } from "@/components/ui/logo"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    description: string
    brands: {
      name: string
      href: string
    }[]
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="grid gap-8 lg:grid-cols-[18rem_minmax(0,1fr)] lg:items-center">
    <Card>
      <CardContent class="p-6 text-sm leading-7">
        {props.description}
      </CardContent>
    </Card>
    <div class="grid gap-4 sm:grid-cols-3">
      {props.brands.map((brand) => (
        <div class="flex min-h-28 items-center justify-center rounded-2xl border bg-muted/20">
          <Logo href={brand.href}><LogoText>{brand.name}</LogoText></Logo>
        </div>
      ))}
    </div>
  </SectionContent>
</Section>
