---
import { CheckIcon } from "@lucide/astro"
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { Button } from "@/components/ui/button"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  title: string
  description: string
  features: string[]
  actions: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
  image: {
    src: ImageMetadata
    alt: string
  }
}

const { title, description, features, actions, image } = Astro.props
---

<Section class="dark bg-background min-h-screen justify-center">
  <SectionContainer class="relative z-10 items-center gap-8 text-center">
    <h1
      class="text-foreground max-w-4xl text-4xl leading-[1.1] font-semibold tracking-tight text-balance sm:text-5xl lg:text-6xl"
    >
      {title}
    </h1>
    <p
      class="text-foreground/80 max-w-2xl text-lg leading-relaxed text-balance"
    >
      {description}
    </p>
    <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2">
      {
        features.map((feature) => (
          <li class="flex items-center gap-2 text-sm">
            <CheckIcon class="text-primary size-4 shrink-0" />
            {feature}
          </li>
        ))
      }
    </ul>
    <div class="flex flex-wrap justify-center gap-3">
      {
        actions.map((action, i) => (
          <Button
            as="a"
            href={action.href}
            size="lg"
            variant={action.variant ?? (i === 0 ? "default" : "secondary")}
          >
            {action.label}
          </Button>
        ))
      }
    </div>
  </SectionContainer>
  <div class="bg-background pointer-events-none absolute inset-0">
    <Image
      src={image.src}
      alt={image.alt}
      class="size-full object-cover opacity-50"
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      loading="eager"
    />
  </div>
</Section>
