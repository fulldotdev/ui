---
import { Badge } from "@/components/ui/badge"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Price, PriceUnit, PriceValue } from "@/components/ui/price"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    badge: string
    title: string
    offer: {
      title: string
      price: number
      currency: string
      unit: string
      description: string
    }
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="rounded-3xl border bg-muted/15 p-8 sm:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <Badge variant="secondary">{props.badge}</Badge>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{props.title}</h2>
      </div>
      <Card class="w-full max-w-sm">
        <CardHeader><CardTitle>{props.offer.title}</CardTitle></CardHeader>
        <CardContent class="flex flex-col gap-4">
          <Price>
            <PriceValue price={props.offer.price} currency={props.offer.currency} />
            <PriceUnit>{props.offer.unit}</PriceUnit>
          </Price>
          <p class="text-muted-foreground text-sm leading-6">{props.offer.description}</p>
        </CardContent>
      </Card>
    </div>
  </SectionContent>
</Section>
