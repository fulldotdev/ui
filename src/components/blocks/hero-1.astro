---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  title: string
  description: string
  badge: {
    label: string
    href: string
  }
  actions: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
  image: {
    src: ImageMetadata
    alt: string
  }
}

const { title, description, badge, actions, image } = Astro.props
---

<Section>
  <SectionContainer class="items-center gap-8 text-center">
    <Badge as="a" href={badge.href} variant="secondary">{badge.label}</Badge>
    <h1
      class="text-foreground max-w-4xl text-4xl leading-[1.1] font-semibold tracking-tight text-balance sm:text-5xl lg:text-6xl"
    >
      {title}
    </h1>
    <p
      class="text-muted-foreground max-w-2xl text-lg leading-relaxed text-balance"
    >
      {description}
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      {
        actions.map((action, i) => (
          <Button
            as="a"
            href={action.href}
            size="lg"
            variant={action.variant ?? (i === 0 ? "default" : "secondary")}
          >
            {action.label}
          </Button>
        ))
      }
    </div>
  </SectionContainer>
  <SectionContainer>
    <Image
      src={image.src}
      alt={image.alt}
      class="aspect-video w-full rounded-xl border object-cover"
      widths={[640, 960, 1280, 1536]}
      sizes="(min-width: 80rem) 80rem, 100vw"
      loading="eager"
    />
  </SectionContainer>
</Section>
