---
import { Banner, BannerContainer } from "@/components/ui/banner"
import { Button } from "@/components/ui/button"

interface Props {
  title: string
  description: string
  actions?: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
}

const { title, description, actions = [] } = Astro.props
---

<Banner variant="floating" storageKey="banner-2">
  <BannerContainer class="gap-4 py-1" showClose={false}>
    <div
      class="flex flex-1 flex-col gap-0.5 @5xl:flex-row @5xl:items-center @5xl:gap-x-4"
    >
      <p class="text-sm font-semibold">{title}</p>
      <p class="text-muted-foreground text-sm">{description}</p>
    </div>
    {
      actions.length > 0 && (
        <div class="flex shrink-0 items-center gap-2">
          {actions.map((action, i) => (
            <Button
              as="a"
              href={action.href}
              size="sm"
              variant={action.variant ?? (i === 0 ? "default" : "outline")}
            >
              {action.label}
            </Button>
          ))}
        </div>
      )
    }
  </BannerContainer>
</Banner>
