---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar"
import { Badge } from "@/components/ui/badge"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  badge: string
  title: string
  description: string
  featured: {
    image: {
      src: ImageMetadata
      alt: string
    }
    category: string
    title: string
    description: string
    href?: string
    author: {
      image?: ImageMetadata
      initials: string
      name: string
      date: string
    }
  }
  articles: {
    image: {
      src: ImageMetadata
      alt: string
    }
    category: string
    title: string
    description: string
    href?: string
    author: {
      image?: ImageMetadata
      initials: string
      name: string
      date: string
    }
  }[]
}

const { badge, title, description, featured, articles } = Astro.props
---

<Section>
  <SectionContainer class="gap-8">
    <div class="mx-auto max-w-2xl text-center">
      <Badge variant="secondary">{badge}</Badge>
      <h2
        class="mt-4 text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
      >
        {title}
      </h2>
      <p class="text-muted-foreground mt-2 text-base leading-7 text-balance">
        {description}
      </p>
    </div>

    <a
      href={featured.href ?? "#"}
      class="group hover:bg-muted/50 focus-visible:ring-ring/50 grid gap-6 rounded-xl p-4 transition-colors focus-visible:ring-2 focus-visible:outline-none lg:grid-cols-2 lg:items-center"
    >
      <Image
        src={featured.image.src}
        alt={featured.image.alt}
        class="aspect-[4/3] rounded-lg object-cover transition-opacity group-hover:opacity-85"
        widths={[640, 960, 1280]}
        sizes="(min-width: 64rem) 50vw, 100vw"
      />
      <div class="flex flex-col gap-4">
        <Badge variant="outline" class="w-fit">{featured.category}</Badge>
        <h3
          class="text-foreground text-2xl leading-tight font-semibold sm:text-3xl"
        >
          {featured.title}
        </h3>
        <p class="text-muted-foreground text-base leading-7">
          {featured.description}
        </p>
        <div class="flex items-center gap-3">
          <Avatar>
            <AvatarImage
              src={featured.author.image}
              alt={featured.author.name}
            />
            <AvatarFallback>{featured.author.initials}</AvatarFallback>
          </Avatar>
          <div class="flex flex-col">
            <p class="text-sm font-medium">{featured.author.name}</p>
            <p class="text-muted-foreground text-xs">{featured.author.date}</p>
          </div>
        </div>
      </div>
    </a>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        articles.map((article) => (
          <a
            href={article.href ?? "#"}
            class="group hover:bg-muted/50 focus-visible:ring-ring/50 flex h-full flex-col gap-4 rounded-xl p-4 transition-colors focus-visible:ring-2 focus-visible:outline-none"
          >
            <Image
              src={article.image.src}
              alt={article.image.alt}
              class="aspect-[16/9] rounded-lg object-cover transition-opacity group-hover:opacity-85"
              widths={[480, 720]}
              sizes="(min-width: 64rem) 22rem, (min-width: 48rem) 50vw, 100vw"
            />
            <div class="flex flex-col gap-2">
              <p class="text-muted-foreground text-sm font-medium">
                {article.category}
              </p>
              <h3 class="text-foreground line-clamp-2 text-lg leading-snug font-semibold">
                {article.title}
              </h3>
              <p class="text-muted-foreground line-clamp-2 text-sm leading-6">
                {article.description}
              </p>
            </div>
            <div class="mt-auto flex items-center gap-3">
              <Avatar>
                <AvatarImage
                  src={article.author.image}
                  alt={article.author.name}
                />
                <AvatarFallback>{article.author.initials}</AvatarFallback>
              </Avatar>
              <div class="flex flex-col">
                <p class="text-sm font-medium">{article.author.name}</p>
                <p class="text-muted-foreground text-xs">
                  {article.author.date}
                </p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </SectionContainer>
</Section>
