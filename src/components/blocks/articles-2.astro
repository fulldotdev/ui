---
import type { ImageMetadata } from "astro"
import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import { Card, CardDescription, CardFooter, CardHeader, CardTitle } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"
import BlockPlaceholder from "@/components/block-placeholder.astro"

type BlockAction = {
  label: string
  href: string
  variant?: "default" | "outline" | "ghost" | "secondary"
}

type BlockImage = {
  src: ImageMetadata
  alt: string
}

interface Props {
  props: {
    badge: string
    title: string
    description: string
    stories: {
      image: BlockImage
      badge: string
      badgeVariant: "secondary" | "outline"
      title: string
      description: string
      action: BlockAction
    }[]
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="gap-8">
    <div class="max-w-2xl">
      <Badge variant="outline">{props.badge}</Badge>
      <h2 class="mt-4 text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{props.title}</h2>
      <p class="text-muted-foreground mt-4 text-base leading-7">{props.description}</p>
    </div>
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {props.stories.map((story) => (
        <Card class="overflow-hidden">
          <BlockPlaceholder image={story.image} class="aspect-[4/3] border-b" />
          <CardHeader>
            <Badge variant={story.badgeVariant} class="w-fit">{story.badge}</Badge>
            <CardTitle class="text-xl leading-snug">{story.title}</CardTitle>
            <CardDescription>{story.description}</CardDescription>
          </CardHeader>
          <CardFooter>
            <Button as="a" href={story.action.href} variant={story.action.variant}>
              {story.action.label}
            </Button>
          </CardFooter>
        </Card>
      ))}
    </div>
  </SectionContent>
</Section>
