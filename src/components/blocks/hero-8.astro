---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { cn } from "@/lib/utils"
import { Button } from "@/components/ui/button"
import { Section, SectionContainer } from "@/components/ui/section"

type Props = {
  class?: string
  title: string
  description: string
  buttons: {
    label: string
    href: string
    variant?: "default" | "outline" | "secondary" | "ghost"
  }[]
  image: {
    src: ImageMetadata
    alt: string
  }
}

const { class: className, title, description, buttons, image } = Astro.props
---

<Section class={cn("", className)}>
  <SectionContainer
    class="grid gap-12 lg:grid-cols-[1fr_3fr] lg:items-center lg:gap-0"
  >
    <div class="flex flex-col gap-6 lg:pr-12">
      <div class="flex flex-col gap-4">
        <h1
          class="text-foreground text-4xl leading-[1.1] font-semibold tracking-tight text-balance sm:text-5xl"
        >
          {title}
        </h1>
        <p class="text-muted-foreground text-lg leading-relaxed">
          {description}
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        {
          buttons.map(({ href, label, ...button }, index) => (
            <Button
              as="a"
              href={href}
              size="lg"
              variant={
                button.variant ?? (index === 0 ? "default" : "secondary")
              }
              {...button}
            >
              {label}
            </Button>
          ))
        }
      </div>
    </div>
    <Image
      src={image.src}
      alt={image.alt}
      class="aspect-4/3 w-full rounded-xl border object-cover"
      widths={[640, 960, 1280]}
      sizes="(min-width: 1024px) 75vw, 100vw"
      loading="eager"
    />
  </SectionContainer>
</Section>
