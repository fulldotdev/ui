---
import { Badge } from "@/components/ui/badge"
import { Logo, LogoText } from "@/components/ui/logo"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    badge: string
    title: string
    brands: {
      name: string
      href: string
    }[]
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="rounded-3xl border bg-muted/20 p-8 sm:p-10">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-xl">
        <Badge variant="secondary">{props.badge}</Badge>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-balance">{props.title}</h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {props.brands.map((brand) => (
          <div class="rounded-xl border bg-background px-5 py-4 text-center text-sm"><Logo href={brand.href}><LogoText>{brand.name}</LogoText></Logo></div>
        ))}
      </div>
    </div>
  </SectionContent>
</Section>
