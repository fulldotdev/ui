---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { cn } from "@/lib/utils"
import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card"
import { Price, PriceUnit, PriceValue } from "@/components/ui/price"
import { Section, SectionContainer } from "@/components/ui/section"

type Props = {
  class?: string
  badge: string
  title: string
  buttons: {
    label: string
    href: string
    variant?: "default" | "outline" | "secondary" | "ghost"
  }[]
  products: {
    image: {
      src: ImageMetadata
      alt: string
    }
    title: string
    description: string
    price: {
      value: number
      currency: string
      unit: string
    }
  }[]
}

const { class: className, badge, title, buttons, products } = Astro.props
---

<Section class={cn("", className)}>
  <SectionContainer class="gap-8">
    <div class="mx-auto max-w-2xl text-center">
      <Badge variant="secondary">{badge}</Badge>
      <h2
        class="mt-4 text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
      >
        {title}
      </h2>
      <div class="mt-4 flex flex-wrap justify-center gap-3">
        {
          buttons.map(({ href, label, ...button }) => (
            <Button as="a" href={href} variant={button.variant}>
              {label}
            </Button>
          ))
        }
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        products.map((product) => (
          <Card class="group/product gap-0 overflow-hidden py-0">
            <div class="overflow-hidden">
              <Image
                src={product.image.src}
                alt={product.image.alt}
                class="aspect-3/4 w-full object-cover transition-transform duration-300 group-hover/product:scale-105"
              />
            </div>
            <CardHeader class="pt-6">
              <CardTitle>{product.title}</CardTitle>
              <CardDescription>{product.description}</CardDescription>
            </CardHeader>
            <CardContent class="pt-4 pb-6">
              <Price>
                <PriceValue
                  price={product.price.value}
                  currency={product.price.currency}
                />
                <PriceUnit>{product.price.unit}</PriceUnit>
              </Price>
            </CardContent>
          </Card>
        ))
      }
    </div>
  </SectionContainer>
</Section>
