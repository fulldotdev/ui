---
import QuoteIcon from "@lucide/astro/icons/quote"
import type { ImageMetadata } from "astro"

import { cn } from "@/lib/utils"
import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar"
import { Rating } from "@/components/ui/rating"
import { Section, SectionContainer } from "@/components/ui/section"
import { Separator } from "@/components/ui/separator"

type Props = {
  class?: string
  featured: {
    quote: string
    image?: ImageMetadata
    initials: string
    name: string
    role: string
  }
  reviews: {
    rating: number
    quote: string
    image?: ImageMetadata
    initials: string
    name: string
    role: string
  }[]
}

const { class: className, featured, reviews } = Astro.props
---

<Section class={cn("", className)}>
  <SectionContainer
    class="grid gap-10 lg:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)] lg:items-start"
  >
    <article class="flex flex-col gap-6 rounded-xl border p-8">
      <QuoteIcon class="text-primary size-8" />
      <blockquote
        class="text-foreground text-2xl leading-snug font-semibold text-balance sm:text-3xl"
      >
        {featured.quote}
      </blockquote>
      <div class="flex items-center gap-3 pt-2">
        <Avatar size="lg">
          <AvatarImage src={featured.image} alt={featured.name} />
          <AvatarFallback>{featured.initials}</AvatarFallback>
        </Avatar>
        <div>
          <p class="text-foreground text-sm font-medium">{featured.name}</p>
          <p class="text-muted-foreground text-xs">{featured.role}</p>
        </div>
      </div>
    </article>
    <div class="grid gap-6">
      {
        reviews.map((item) => (
          <article class="flex flex-col">
            <Separator />
            <div class="flex flex-col gap-3 pt-6">
              <Rating value={item.rating} />
              <p class="text-muted-foreground text-sm leading-relaxed">
                {item.quote}
              </p>
              <div class="flex items-center gap-3 pt-1">
                <Avatar>
                  <AvatarImage src={item.image} alt={item.name} />
                  <AvatarFallback>{item.initials}</AvatarFallback>
                </Avatar>
                <div>
                  <p class="text-foreground text-sm font-medium">{item.name}</p>
                  <p class="text-muted-foreground text-xs">{item.role}</p>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </SectionContainer>
</Section>
