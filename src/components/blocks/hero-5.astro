---
import { CheckIcon } from "@lucide/astro"
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { Avatar, AvatarFallback, AvatarGroup } from "@/components/ui/avatar"
import { Button } from "@/components/ui/button"
import { Rating } from "@/components/ui/rating"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  title: string
  description: string
  features: string[]
  actions: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
  socialProof: {
    avatars: string[]
    rating: number
    text: string
  }
  image: {
    src: ImageMetadata
    alt: string
  }
}

const { title, description, features, actions, socialProof, image } =
  Astro.props
---

<Section>
  <SectionContainer class="grid gap-12 lg:grid-cols-2 lg:items-center">
    <div class="flex flex-col gap-6">
      <div class="flex flex-col gap-4">
        <h1
          class="text-foreground text-4xl leading-[1.1] font-semibold tracking-tight text-balance sm:text-5xl"
        >
          {title}
        </h1>
        <p class="text-muted-foreground text-lg leading-relaxed">
          {description}
        </p>
      </div>
      <ul class="flex flex-col gap-3">
        {
          features.map((feature) => (
            <li class="flex items-center gap-3 text-sm">
              <CheckIcon class="text-primary size-4 shrink-0" />
              {feature}
            </li>
          ))
        }
      </ul>
      <div class="flex flex-wrap gap-3">
        {
          actions.map((action, i) => (
            <Button
              as="a"
              href={action.href}
              size="lg"
              variant={action.variant ?? (i === 0 ? "default" : "secondary")}
            >
              {action.label}
            </Button>
          ))
        }
      </div>
      <div class="flex items-center gap-3">
        <AvatarGroup>
          {
            socialProof.avatars.map((initials) => (
              <Avatar class="ring-background size-11 ring">
                <AvatarFallback>{initials}</AvatarFallback>
              </Avatar>
            ))
          }
        </AvatarGroup>
        <div class="flex flex-col gap-0.5">
          <Rating value={socialProof.rating} />
          <span class="text-muted-foreground text-xs">{socialProof.text}</span>
        </div>
      </div>
    </div>
    <Image
      src={image.src}
      alt={image.alt}
      class="aspect-[4/3] w-full rounded-xl border object-cover"
      widths={[640, 960, 1280]}
      sizes="(min-width: 1024px) 50vw, 100vw"
      loading="eager"
    />
  </SectionContainer>
</Section>
