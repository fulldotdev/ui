---
import PlaceholderImage from "@/assets/placeholder.webp"
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { Button } from "@/components/ui/button"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  title: string
  description: string
  actions?: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
  image?: {
    src: ImageMetadata
    alt: string
  }
}

const {
  title,
  description,
  actions,
  image = { src: PlaceholderImage, alt: "Content image" },
} = Astro.props
---

<Section>
  <SectionContainer class="gap-8">
    <div
      class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
    >
      <div class="max-w-2xl">
        <h2
          class="text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
        >
          {title}
        </h2>
        <p
          class="text-muted-foreground mt-4 text-lg leading-relaxed text-balance"
        >
          {description}
        </p>
      </div>
      {
        actions?.length ? (
          <div class="flex flex-wrap gap-3">
            {actions.map((action, i) => (
              <Button
                as="a"
                href={action.href}
                size="lg"
                variant={action.variant ?? (i === 0 ? "default" : "secondary")}
              >
                {action.label}
              </Button>
            ))}
          </div>
        ) : null
      }
    </div>
  </SectionContainer>
  <SectionContainer>
    <Image
      src={image.src}
      alt={image.alt}
      class="aspect-video w-full rounded-xl border object-cover"
      widths={[640, 960, 1280, 1536]}
      sizes="(min-width: 80rem) 80rem, 100vw"
    />
  </SectionContainer>
</Section>
