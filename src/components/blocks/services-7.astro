---
import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import { Section, SectionContent } from "@/components/ui/section"

type BlockAction = {
  label: string
  href: string
  variant?: "default" | "outline" | "ghost" | "secondary"
}

interface Props {
  props: {
    badge: string
    title: string
    description: string
    actions: [BlockAction, BlockAction]
  }
}

const { props } = Astro.props
---

<Section class="overflow-hidden rounded-3xl border bg-foreground text-background">
  <SectionContent class="grid gap-8 p-8 sm:p-10 lg:grid-cols-[minmax(0,1fr)_16rem] lg:items-center">
    <div class="flex flex-col gap-5">
      <Badge variant="secondary" class="w-fit">{props.badge}</Badge>
      <h2 class="text-4xl font-semibold tracking-tight text-balance sm:text-5xl">{props.title}</h2>
      <p class="max-w-2xl text-sm leading-7 text-background/75 sm:text-base">{props.description}</p>
    </div>
    <div class="flex flex-col gap-3 lg:items-end">
      {
        props.actions.map((action) => (
          <Button as="a" href={action.href} variant={action.variant}>
            {action.label}
          </Button>
        ))
      }
    </div>
  </SectionContent>
</Section>
