---
import ArrowLeft from "@lucide/astro/icons/arrow-left"
import ArrowRight from "@lucide/astro/icons/arrow-right"
import Check from "@lucide/astro/icons/check"
import Copy from "@lucide/astro/icons/copy"

import { Button } from "@/components/ui/button"
import {
  Card,
  CardDescription,
  CardFooter,
  CardHeader,
} from "@/components/ui/card"
import { SectionContainer } from "@/components/ui/section"
import {
  Toc,
  TocMenu,
  TocMenuItem,
  TocMenuLink,
  TocTitle,
} from "@/components/ui/toc"
import {
  Typography,
  TypographyH1,
  TypographyLead,
} from "@/components/ui/typography"

type Props = {
  title: string
  description?: string
  copyButton?: {
    id: string
    source: string
  }
  tocItems: {
    depth: number
    href: string
    label: string
  }[]
  callout?: {
    description: string
    button: {
      text: string
      href: string
      variant?: "default" | "outline" | "secondary" | "ghost"
    }
  }
  previousPage?: {
    href: string
    title: string
  }
  nextPage?: {
    href: string
    title: string
  }
  labels: {
    copyPage: string
    pagination: {
      previous: string
      next: string
      ariaLabel: string
    }
    toc: string
  }
}

const {
  title,
  description,
  copyButton,
  tocItems,
  callout,
  previousPage,
  nextPage,
  labels,
} = Astro.props
const showCopyButton = Boolean(copyButton)
const showPagination = Boolean(previousPage || nextPage)
---

<SectionContainer
  class="gap-10 pt-10 pb-8 sm:pt-12 sm:pb-10 xl:grid xl:grid-cols-[minmax(0,1fr)_16rem] xl:items-start xl:gap-x-16"
>
  <div class="mx-auto flex w-full max-w-3xl min-w-0 flex-col gap-10">
    <header
      class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between"
    >
      <div class="flex min-w-0 flex-1 flex-col gap-2">
        <TypographyH1
          size="sm"
          class="text-foreground text-left tracking-tight"
        >
          {title}
        </TypographyH1>
        {
          description && (
            <TypographyLead size="sm" class="max-w-2xl leading-7">
              {description}
            </TypographyLead>
          )
        }
      </div>
      {
        showCopyButton && (
          <Button
            id={copyButton?.id}
            type="button"
            variant="outline"
            size="xs"
            class="shrink-0 self-start"
            data-source={copyButton?.source}
            aria-label={labels.copyPage}
          >
            <Copy class="docs-copy-icon size-3.5" />
            <Check class="docs-check-icon hidden size-3.5" />
            <span>{labels.copyPage}</span>
          </Button>
        )
      }
    </header>

    <Typography as="article" size="sm">
      <slot />
    </Typography>

    {
      showPagination && (
        <nav
          class="grid gap-3 sm:grid-cols-2"
          aria-label={labels.pagination.ariaLabel}
        >
          {previousPage ? (
            <Button
              as="a"
              href={previousPage.href}
              variant="outline"
              class="h-auto w-full items-center justify-start gap-3 rounded-xl px-4 py-3 whitespace-normal"
            >
              <ArrowLeft class="size-4" />
              <span class="flex min-w-0 flex-col items-start">
                <span class="text-muted-foreground text-xs uppercase">
                  {labels.pagination.previous}
                </span>
                <span class="truncate text-sm font-medium">
                  {previousPage.title}
                </span>
              </span>
            </Button>
          ) : (
            <div class="hidden sm:block" aria-hidden="true" />
          )}

          {nextPage ? (
            <Button
              as="a"
              href={nextPage.href}
              variant="outline"
              class="h-auto w-full items-center justify-end gap-3 rounded-xl px-4 py-3 text-right whitespace-normal"
            >
              <span class="flex min-w-0 flex-col items-end">
                <span class="text-muted-foreground text-xs uppercase">
                  {labels.pagination.next}
                </span>
                <span class="truncate text-sm font-medium">
                  {nextPage.title}
                </span>
              </span>
              <ArrowRight class="size-4" />
            </Button>
          ) : (
            <div class="hidden sm:block" aria-hidden="true" />
          )}
        </nav>
      )
    }
  </div>

  {
    (
      <aside class="hidden w-64 xl:sticky xl:top-12 xl:mr-0 xl:ml-auto xl:block xl:self-start">
        <div class="flex flex-col gap-6">
          {tocItems.length > 0 && (
            <Toc aria-label={labels.toc}>
              <TocTitle>{labels.toc}</TocTitle>
              <TocMenu>
                {tocItems.map((item) => (
                  <TocMenuItem>
                    <TocMenuLink href={item.href} depth={item.depth}>
                      {item.label}
                    </TocMenuLink>
                  </TocMenuItem>
                ))}
              </TocMenu>
            </Toc>
          )}

          {callout && (
            <Card size="sm">
              <CardHeader>
                <CardDescription>{callout.description}</CardDescription>
              </CardHeader>
              <CardFooter>
                <Button
                  as="a"
                  href={callout.button.href}
                  variant={callout.button.variant}
                  size="sm"
                  target="_blank"
                  rel="noreferrer"
                >
                  {callout.button.text}
                </Button>
              </CardFooter>
            </Card>
          )}
        </div>
      </aside>
    )
  }
</SectionContainer>

<script is:inline define:vars={{ copyButtonId: copyButton?.id }}>
  const button = copyButtonId ? document.getElementById(copyButtonId) : null

  if (button instanceof HTMLButtonElement) {
    button.addEventListener("click", async () => {
      const source = button.dataset.source

      if (!source) return

      try {
        await navigator.clipboard.writeText(source)
        button.querySelector(".docs-copy-icon")?.classList.add("hidden")
        button.querySelector(".docs-check-icon")?.classList.remove("hidden")

        window.setTimeout(() => {
          button.querySelector(".docs-copy-icon")?.classList.remove("hidden")
          button.querySelector(".docs-check-icon")?.classList.add("hidden")
        }, 1200)
      } catch {
        // Ignore clipboard failures; the button remains available for retry.
      }
    })
  }
</script>
