---
import { ArrowLeft, ArrowRight, Check, Copy } from "@lucide/astro"

import { Button } from "@/components/ui/button"
import {
  Card,
  CardDescription,
  CardFooter,
  CardHeader,
} from "@/components/ui/card"
import {
  Toc,
  TocMenu,
  TocMenuItem,
  TocMenuLink,
  TocTitle,
} from "@/components/ui/toc"
import {
  Typography,
  TypographyH1,
  TypographyLead,
} from "@/components/ui/typography"

type ComponentLink = {
  href: string
  title: string
  description?: string
}

type TocItem = {
  depth: number
  href: string
  label: string
}

type Callout = {
  description: string
  action: {
    text: string
    href: string
  }
}

type CopyButton = {
  id: string
  source: string
}

type PaginationLink = {
  href: string
  title: string
}

type Props = {
  title: string
  description?: string
  copyButton?: CopyButton
  showComponentLinks?: boolean
  componentLinks?: ComponentLink[]
  tocItems?: TocItem[]
  callout?: Callout
  previousPage?: PaginationLink
  nextPage?: PaginationLink
}

const props: Props = Astro.props
const tocItems = props.tocItems ?? []
const componentLinks = props.componentLinks ?? []
const showCopyButton = Boolean(props.copyButton)
const showPagination = Boolean(props.previousPage || props.nextPage)
---

<div class="mx-auto w-full px-6 pt-10 pb-8 sm:px-8 sm:pt-12 sm:pb-10">
  <div
    class="flex flex-col gap-10 xl:grid xl:grid-cols-[minmax(0,1fr)_16rem] xl:items-start xl:gap-x-16"
  >
    <div class="mx-auto flex w-full max-w-3xl min-w-0 flex-col gap-10">
      <header
        class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between"
      >
        <div class="flex min-w-0 flex-1 flex-col gap-2">
          <TypographyH1
            class="text-foreground text-left text-3xl tracking-tight sm:text-4xl"
          >
            {props.title}
          </TypographyH1>
          {
            props.description && (
              <TypographyLead class="max-w-2xl text-base leading-7">
                {props.description}
              </TypographyLead>
            )
          }
        </div>
        {
          showCopyButton && (
            <Button
              id={props.copyButton?.id}
              type="button"
              variant="outline"
              size="xs"
              class="shrink-0 self-start"
              data-source={props.copyButton?.source}
              aria-label="Copy page markdown"
            >
              <Copy class="docs-copy-icon size-3.5" />
              <Check class="docs-check-icon hidden size-3.5" />
              <span>Copy Page</span>
            </Button>
          )
        }
      </header>

      {
        props.showComponentLinks && (
          <section class="flex flex-col gap-2">
            {componentLinks.map((item) => (
              <a
                href={item.href}
                class="bg-muted/40 hover:bg-muted/60 rounded-lg px-4 py-4 transition-colors"
              >
                <span class="text-sm font-medium">{item.title}</span>
                {item.description && (
                  <span class="text-muted-foreground text-sm leading-6">
                    {item.description}
                  </span>
                )}
              </a>
            ))}
          </section>
        )
      }

      <Typography as="article">
        <slot />
      </Typography>

      {
        showPagination && (
          <nav
            class="grid gap-3 sm:grid-cols-2"
            aria-label="Document pagination"
          >
            {props.previousPage ? (
              <Button
                as="a"
                href={props.previousPage.href}
                variant="outline"
                class="h-auto w-full items-center justify-start gap-3 rounded-xl px-4 py-3 whitespace-normal"
              >
                <ArrowLeft class="size-4" />
                <span class="flex min-w-0 flex-col items-start">
                  <span class="text-muted-foreground text-xs uppercase">
                    Previous
                  </span>
                  <span class="truncate text-sm font-medium">
                    {props.previousPage.title}
                  </span>
                </span>
              </Button>
            ) : (
              <div class="hidden sm:block" aria-hidden="true"></div>
            )}

            {props.nextPage ? (
              <Button
                as="a"
                href={props.nextPage.href}
                variant="outline"
                class="h-auto w-full items-center justify-end gap-3 rounded-xl px-4 py-3 text-right whitespace-normal"
              >
                <span class="flex min-w-0 flex-col items-end">
                  <span class="text-muted-foreground text-xs uppercase">
                    Next
                  </span>
                  <span class="truncate text-sm font-medium">
                    {props.nextPage.title}
                  </span>
                </span>
                <ArrowRight class="size-4" />
              </Button>
            ) : (
              <div class="hidden sm:block" aria-hidden="true"></div>
            )}
          </nav>
        )
      }
    </div>

    {
      <aside
        class="hidden w-64 xl:sticky xl:top-12 xl:mr-0 xl:ml-auto xl:block xl:self-start"
      >
        <div class="flex flex-col gap-6">
          {
            tocItems.length > 0 && (
              <Toc aria-label="On This Page">
                <TocTitle>On This Page</TocTitle>
                <TocMenu>
                  {tocItems.map((item) => (
                    <TocMenuItem>
                      <TocMenuLink href={item.href} depth={item.depth}>
                        {item.label}
                      </TocMenuLink>
                    </TocMenuItem>
                  ))}
                </TocMenu>
              </Toc>
            )
          }

          {
            props.callout && (
              <Card size="sm">
                <CardHeader>
                  <CardDescription>
                    {props.callout.description}
                  </CardDescription>
                </CardHeader>
                <CardFooter>
                  <Button
                    as="a"
                    href={props.callout.action.href}
                    variant="outline"
                    size="sm"
                    target="_blank"
                    rel="noreferrer"
                  >
                    {props.callout.action.text}
                  </Button>
                </CardFooter>
              </Card>
            )
          }
        </div>
      </aside>
    }
  </div>
</div>

<script is:inline define:vars={{ copyButtonId: props.copyButton?.id }}>
  const button = copyButtonId ? document.getElementById(copyButtonId) : null

  if (button instanceof HTMLButtonElement) {
    button.addEventListener("click", async () => {
      const source = button.dataset.source

      if (!source) return

      try {
        await navigator.clipboard.writeText(source)
        button.querySelector(".docs-copy-icon")?.classList.add("hidden")
        button.querySelector(".docs-check-icon")?.classList.remove("hidden")

        window.setTimeout(() => {
          button.querySelector(".docs-copy-icon")?.classList.remove("hidden")
          button.querySelector(".docs-check-icon")?.classList.add("hidden")
        }, 1200)
      } catch {
        // Ignore clipboard failures; the button remains available for retry.
      }
    })
  }
</script>
