---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { Avatar, AvatarFallback, AvatarGroup } from "@/components/ui/avatar"
import { Button } from "@/components/ui/button"
import { Rating } from "@/components/ui/rating"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  title: string
  description: string
  actions: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
  socialProof: {
    avatars: string[]
    rating: number
    text: string
  }
  image: {
    src: ImageMetadata
    alt: string
  }
}

const { title, description, actions, socialProof, image } = Astro.props
---

<Section class="dark bg-background min-h-screen justify-start">
  <SectionContainer
    class="relative z-10 grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center"
  >
    <div class="flex flex-col gap-5">
      <h1
        class="text-foreground text-4xl leading-[1.1] font-semibold tracking-tight text-balance sm:text-5xl"
      >
        {title}
      </h1>
      <p class="text-foreground/80 max-w-2xl text-lg leading-relaxed">
        {description}
      </p>
    </div>
    <div class="flex shrink-0 flex-col gap-5">
      <div class="flex flex-wrap gap-3">
        {
          actions.map((action, i) => (
            <Button
              as="a"
              href={action.href}
              size="lg"
              class="w-full"
              variant={action.variant ?? (i === 0 ? "default" : "secondary")}
            >
              {action.label}
            </Button>
          ))
        }
      </div>
      <div class="flex items-center gap-3">
        <AvatarGroup>
          {
            socialProof.avatars.map((initials) => (
              <Avatar class="ring-background size-11 ring">
                <AvatarFallback>{initials}</AvatarFallback>
              </Avatar>
            ))
          }
        </AvatarGroup>
        <div class="flex flex-col gap-0.5">
          <Rating value={socialProof.rating} />
          <span class="text-muted-foreground text-xs">{socialProof.text}</span>
        </div>
      </div>
    </div>
  </SectionContainer>
  <div
    class="bg-background pointer-events-none absolute inset-0 mask-y-from-0% mask-y-to-100%"
  >
    <Image
      src={image.src}
      alt={image.alt}
      class="size-full object-cover opacity-75"
      widths={[640, 960, 1280, 1920]}
      sizes="100vw"
      loading="eager"
    />
  </div>
</Section>
