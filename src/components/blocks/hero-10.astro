---
import { Button } from "@/components/ui/button"
import { Field, FieldGroup, FieldLabel, FieldSet, FieldLegend } from "@/components/ui/field"
import { Input } from "@/components/ui/input"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    title: string
    description: string
    form: {
      legend: string
      emailLabel: string
      emailPlaceholder: string
      buttonLabel: string
    }
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-center">
    <div class="flex flex-col gap-5">
      <h1 class="text-4xl font-semibold tracking-tight text-balance sm:text-5xl">{props.title}</h1>
      <p class="text-muted-foreground text-lg leading-8">{props.description}</p>
    </div>
    <div class="rounded-3xl border bg-muted/20 p-6">
      <FieldSet>
        <FieldLegend>{props.form.legend}</FieldLegend>
        <FieldGroup>
          <Field>
            <FieldLabel for="hero-email-10">{props.form.emailLabel}</FieldLabel>
            <Input id="hero-email-10" type="email" placeholder={props.form.emailPlaceholder} />
          </Field>
          <Button>{props.form.buttonLabel}</Button>
        </FieldGroup>
      </FieldSet>
    </div>
  </SectionContent>
</Section>
