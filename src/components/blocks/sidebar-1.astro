---
import { Image } from "astro:assets"
import type { ComponentProps } from "astro/types"
import { Github } from "simple-icons-astro"

import type { GlobalSchema } from "@/schemas/global"
import { Button } from "@/components/ui/button"
import {
  SidebarContent,
  SidebarFooter,
  SidebarGroup,
  SidebarGroupLabel,
  SidebarHeader,
  SidebarMenu,
  SidebarMenuButton,
  SidebarMenuItem,
  Sidebar as UiSidebar,
} from "@/components/ui/sidebar"
import { ThemeToggle } from "@/components/ui/theme-toggle"
import SiteSearch from "@/components/site-search.astro"

type NavItem = {
  label: string
  href: string
  isActive?: boolean
}

type NavGroup = {
  label: string
  items: NavItem[]
}

type Props = {
  props: ComponentProps<typeof UiSidebar> & {
    global: GlobalSchema
    navGroups: NavGroup[]
    github: {
      href: string
      ariaLabel: string
      count: string
    }
  }
}

const { props } = Astro.props
const { global, navGroups, github, ...sidebarProps } = props
---

<UiSidebar {...sidebarProps}>
  <SidebarHeader class="px-4">
    <a href="/" class="flex h-10 items-center gap-2 text-lg font-semibold">
      <Image
        src={global.logo.dark}
        alt={`${global.name} logo`}
        class="size-5 shrink-0 dark:hidden"
      />
      <Image
        src={global.logo.light}
        alt={`${global.name} logo`}
        class="hidden size-5 shrink-0 dark:block"
      />
      <span>{global.name}</span>
    </a>
    <SiteSearch class="w-full justify-start" />
  </SidebarHeader>
  <SidebarContent>
    {
      navGroups.map((group) => (
        <SidebarGroup>
          <SidebarGroupLabel>{group.label}</SidebarGroupLabel>
          <SidebarMenu>
            {group.items.map((item) => (
              <SidebarMenuItem>
                <SidebarMenuButton href={item.href} isActive={item.isActive}>
                  <span>{item.label}</span>
                </SidebarMenuButton>
              </SidebarMenuItem>
            ))}
          </SidebarMenu>
        </SidebarGroup>
      ))
    }
  </SidebarContent>
  <SidebarFooter>
    <div class="flex items-center gap-1">
      <Button
        as="a"
        href={github.href}
        variant="ghost"
        size="sm"
        target="_blank"
        rel="noreferrer"
        aria-label={github.ariaLabel}
      >
        <Github class="size-4" fill="currentColor" aria-hidden="true" />
        <span>{github.count}</span>
      </Button>
      <ThemeToggle variant="ghost" size="icon-sm" />
    </div>
  </SidebarFooter>
</UiSidebar>
