---
import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import { Section, SectionContent } from "@/components/ui/section"

type BlockAction = {
  label: string
  href: string
  variant?: "default" | "outline" | "ghost" | "secondary"
}

interface Props {
  props: {
    badge: string
    title: string
    description: string
    actions: [BlockAction, BlockAction]
  }
}

const { props } = Astro.props
---

<Section class="overflow-hidden rounded-3xl border">
  <SectionContent class="gap-8 p-8 sm:p-10 lg:p-12">
    <div class="max-w-2xl">
      <Badge variant="outline">{props.badge}</Badge>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-balance sm:text-5xl">{props.title}</h1>
      <p class="text-muted-foreground mt-4 text-lg leading-8">{props.description}</p>
    </div>
    <div class="flex flex-wrap gap-3">
      {
        props.actions.map((action) => (
          <Button as="a" href={action.href} variant={action.variant}>
            {action.label}
          </Button>
        ))
      }
    </div>
  </SectionContent>
</Section>
