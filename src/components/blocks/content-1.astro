---
import { Badge } from "@/components/ui/badge"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    badge: string
    title: string
    description: string
    body: string
    stat: {
      value: string
      description: string
    }
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)] lg:items-center">
    <div class="flex flex-col gap-4">
      <Badge variant="outline" class="w-fit">{props.badge}</Badge>
      <h2 class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{props.title}</h2>
      <p class="text-muted-foreground text-base leading-7">{props.description}</p>
      <p class="text-base leading-7">{props.body}</p>
    </div>
    <Card>
      <CardHeader>
        <CardTitle>{props.stat.value}</CardTitle>
      </CardHeader>
      <CardContent class="text-muted-foreground text-sm leading-6">{props.stat.description}</CardContent>
    </Card>
  </SectionContent>
</Section>
