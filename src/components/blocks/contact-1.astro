---
import LayoutGridIcon from "@lucide/astro/icons/layout-grid"

import { Button } from "@/components/ui/button"
import {
  Field,
  FieldDescription,
  FieldGroup,
  FieldLabel,
  FieldLegend,
  FieldSet,
} from "@/components/ui/field"
import { Input } from "@/components/ui/input"
import { Section, SectionContainer } from "@/components/ui/section"
import { Textarea } from "@/components/ui/textarea"

interface Props {
  title: string
  description: string
  items: {
    icon: typeof LayoutGridIcon
    title: string
    description: string
  }[]
  form: {
    legend: string
    nameLabel: string
    namePlaceholder: string
    emailLabel: string
    emailPlaceholder: string
    messageLabel: string
    messagePlaceholder: string
    messageDescription: string
    actionLabel: string
  }
}

const { title, description, items, form } = Astro.props
---

<Section>
  <SectionContainer class="items-center gap-6 text-center">
    <div class="flex max-w-2xl flex-col items-center gap-4">
      <h2
        class="text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
      >
        {title}
      </h2>
      <p
        class="text-muted-foreground max-w-2xl text-lg leading-relaxed text-balance"
      >
        {description}
      </p>
    </div>
  </SectionContainer>
  <SectionContainer>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        items.map((item) => {
          const Icon = item.icon
          return (
            <div class="flex flex-col gap-3 rounded-xl border p-5">
              <div class="bg-primary/10 text-primary flex size-10 items-center justify-center rounded-lg">
                <Icon class="size-5" />
              </div>
              <h3 class="text-foreground text-sm font-medium">{item.title}</h3>
              <p class="text-muted-foreground text-sm leading-relaxed">
                {item.description}
              </p>
            </div>
          )
        })
      }
    </div>
  </SectionContainer>
  <SectionContainer>
    <div class="mx-auto w-full max-w-2xl rounded-xl border p-6 sm:p-8">
      <FieldSet>
        <FieldLegend class="sr-only">{form.legend}</FieldLegend>
        <FieldGroup>
          <div class="grid gap-4 md:grid-cols-2">
            <Field>
              <FieldLabel for="contact-name-1">{form.nameLabel}</FieldLabel>
              <Input id="contact-name-1" placeholder={form.namePlaceholder} />
            </Field>
            <Field>
              <FieldLabel for="contact-email-1">{form.emailLabel}</FieldLabel>
              <Input
                id="contact-email-1"
                type="email"
                placeholder={form.emailPlaceholder}
              />
            </Field>
          </div>
          <Field>
            <FieldLabel for="contact-message-1">{form.messageLabel}</FieldLabel>
            <Textarea
              id="contact-message-1"
              rows={5}
              placeholder={form.messagePlaceholder}
            />
            <FieldDescription>{form.messageDescription}</FieldDescription>
          </Field>
          <Button size="lg" class="w-full">{form.actionLabel}</Button>
        </FieldGroup>
      </FieldSet>
    </div>
  </SectionContainer>
</Section>
