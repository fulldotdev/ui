---
import { Button } from "@/components/ui/button"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
import { Field, FieldDescription, FieldGroup, FieldLabel, FieldSet, FieldLegend } from "@/components/ui/field"
import { Input } from "@/components/ui/input"
import { Section, SectionContent } from "@/components/ui/section"
import { Textarea } from "@/components/ui/textarea"

interface Props {
  props: {
    title: string
    description: string
    highlights: {
      title: string
      description: string
    }[]
    form: {
      title: string
      description: string
      legend: string
      nameLabel: string
      namePlaceholder: string
      emailLabel: string
      emailPlaceholder: string
      messageLabel: string
      messagePlaceholder: string
      messageDescription: string
      actionLabel: string
    }
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_26rem] lg:items-start">
    <div class="flex flex-col gap-4">
      <h2 class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{props.title}</h2>
      <p class="text-muted-foreground max-w-2xl text-base leading-7">{props.description}</p>
      <div class="grid gap-4 sm:grid-cols-2">
        {
          props.highlights.map((highlight) => (
            <Card>
              <CardContent class="p-5">
                <p class="font-medium">{highlight.title}</p>
                <p class="text-muted-foreground text-sm">{highlight.description}</p>
              </CardContent>
            </Card>
          ))
        }
      </div>
    </div>

    <Card>
      <CardHeader>
        <CardTitle>{props.form.title}</CardTitle>
        <CardDescription>{props.form.description}</CardDescription>
      </CardHeader>
      <CardContent>
        <FieldSet>
          <FieldLegend class="sr-only">{props.form.legend}</FieldLegend>
          <FieldGroup>
            <Field>
              <FieldLabel for="contact-name-1">{props.form.nameLabel}</FieldLabel>
              <Input id="contact-name-1" placeholder={props.form.namePlaceholder} />
            </Field>
            <Field>
              <FieldLabel for="contact-email-1">{props.form.emailLabel}</FieldLabel>
              <Input id="contact-email-1" type="email" placeholder={props.form.emailPlaceholder} />
            </Field>
            <Field>
              <FieldLabel for="contact-message-1">{props.form.messageLabel}</FieldLabel>
              <Textarea id="contact-message-1" rows={5} placeholder={props.form.messagePlaceholder} />
              <FieldDescription>{props.form.messageDescription}</FieldDescription>
            </Field>
            <Button>{props.form.actionLabel}</Button>
          </FieldGroup>
        </FieldSet>
      </CardContent>
    </Card>
  </SectionContent>
</Section>
