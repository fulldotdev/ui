---
import { Button } from "@/components/ui/button"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"

type BlockAction = {
  label: string
  href: string
  variant?: "default" | "outline" | "ghost" | "secondary"
}

interface Props {
  props: {
    title: string
    description: string
    actions: [BlockAction, BlockAction]
    nextSections: {
      title: string
      items: string[]
    }
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_24rem] lg:items-center">
    <div class="flex flex-col gap-5">
      <h1 class="text-4xl font-semibold tracking-tight text-balance sm:text-5xl lg:text-6xl">{props.title}</h1>
      <p class="text-muted-foreground max-w-2xl text-lg leading-8">{props.description}</p>
      <div class="flex flex-wrap gap-3">
        {
          props.actions.map((action) => (
            <Button as="a" href={action.href} variant={action.variant}>
              {action.label}
            </Button>
          ))
        }
      </div>
    </div>
    <Card>
      <CardHeader><CardTitle>{props.nextSections.title}</CardTitle></CardHeader>
      <CardContent class="grid gap-3 text-sm">
        {props.nextSections.items.map((item) => (
          <div class="rounded-xl border px-4 py-3">{item}</div>
        ))}
      </CardContent>
    </Card>
  </SectionContent>
</Section>
