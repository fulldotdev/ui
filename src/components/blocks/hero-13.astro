---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { Button } from "@/components/ui/button"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  title: string
  description: string
  actions: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
  image: {
    src: ImageMetadata
    alt: string
  }
}

const { title, description, actions, image } = Astro.props
---

<Section>
  <SectionContainer class="grid gap-12 lg:grid-cols-[1fr_3fr] lg:items-start">
    <div class="flex flex-col gap-6 pt-8">
      <div class="flex flex-col gap-4">
        <h1
          class="text-foreground text-2xl leading-[1.2] font-semibold tracking-tight text-balance sm:text-3xl"
        >
          {title}
        </h1>
        <p class="text-muted-foreground text-base leading-relaxed">
          {description}
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        {
          actions.map((action, i) => (
            <Button
              as="a"
              href={action.href}
              variant={action.variant ?? (i === 0 ? "default" : "secondary")}
            >
              {action.label}
            </Button>
          ))
        }
      </div>
    </div>
    <Image
      src={image.src}
      alt={image.alt}
      class="aspect-[4/3] w-full rounded-xl border object-cover"
      widths={[640, 960, 1280]}
      sizes="(min-width: 1024px) 75vw, 100vw"
      loading="eager"
    />
  </SectionContainer>
</Section>
