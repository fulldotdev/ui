---
import { cn } from "@/lib/utils"
import { Icon } from "@/components/ui/icon"
import { Section, SectionContainer } from "@/components/ui/section"

type Props = {
  class?: string
  title: string
  description: string
  links: {
    href: string
    title: string
    description: string
    preview?: string
  }[]
}

const { class: className, title, description, links } = Astro.props
---

<Section class={cn("", className)}>
  <SectionContainer class="gap-10">
    <div class="flex min-w-0 flex-col gap-4 border-b pb-8">
      <h2
        class="text-foreground text-2xl font-semibold tracking-tight text-balance sm:text-3xl"
      >
        {title}
      </h2>
      <p class="text-muted-foreground max-w-2xl text-base leading-7">
        {description}
      </p>
    </div>

    <div class="grid gap-2 md:grid-cols-2 xl:grid-cols-3">
      {
        links.map((item) => (
          <a
            href={item.href}
            class="bg-muted/40 hover:bg-muted/60 focus-visible:ring-ring/50 group/link rounded-lg px-4 py-4 transition-colors focus-visible:ring-2 focus-visible:outline-none"
          >
            <span class="flex min-w-0 items-center justify-between gap-3">
              <span class="text-sm font-medium">{item.title}</span>
              <Icon
                name="arrow-right"
                class="text-muted-foreground size-3.5 shrink-0 transition-transform group-hover/link:translate-x-0.5"
              />
            </span>
            <span class="text-muted-foreground mt-1 block text-sm leading-6">
              {item.description}
            </span>
          </a>
        ))
      }
    </div>
  </SectionContainer>
</Section>
