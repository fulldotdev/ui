---
import { Card, CardContent } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    items: {
      number: string
      title: string
      description: string
    }[]
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="grid gap-4 md:grid-cols-3">
    {props.items.map((item) => (
      <Card>
        <CardContent class="flex flex-col gap-4 p-6">
          <div class="text-primary text-sm font-medium">{item.number}</div>
          <h3 class="text-xl font-medium">{item.title}</h3>
          <p class="text-muted-foreground text-sm leading-6">{item.description}</p>
        </CardContent>
      </Card>
    ))}
  </SectionContent>
</Section>
