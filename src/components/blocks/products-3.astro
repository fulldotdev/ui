---
import { Badge } from "@/components/ui/badge"
import { Card, CardContent } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    badge: string
    title: string
    groups: {
      label: string
      description: string
    }[]
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="grid gap-8 lg:grid-cols-[18rem_minmax(0,1fr)] lg:items-start">
    <div class="flex flex-col gap-4">
      <Badge variant="secondary">{props.badge}</Badge>
      <h2 class="text-3xl font-semibold tracking-tight text-balance">{props.title}</h2>
    </div>
    <div class="grid gap-3">
      {props.groups.map((group) => (
        <Card>
          <CardContent class="grid gap-4 p-5 md:grid-cols-[10rem_minmax(0,1fr)] md:items-center">
            <div class="text-primary text-sm font-medium">{group.label}</div>
            <p class="text-muted-foreground text-sm leading-6">{group.description}</p>
          </CardContent>
        </Card>
      ))}
    </div>
  </SectionContent>
</Section>
