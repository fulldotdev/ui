---
import { Badge } from "@/components/ui/badge"
import { Logo, LogoText } from "@/components/ui/logo"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    badge: string
    title: string
    brands: {
      name: string
      href: string
    }[]
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="items-center gap-8 text-center">
    <Badge variant="outline">{props.badge}</Badge>
    <h2 class="max-w-3xl text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{props.title}</h2>
    <div class="grid w-full gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
      {props.brands.map((brand) => (
        <div class="flex items-center justify-center rounded-2xl border px-4 py-5 text-muted-foreground">
          <Logo href={brand.href}><LogoText>{brand.name}</LogoText></Logo>
        </div>
      ))}
    </div>
  </SectionContent>
</Section>
