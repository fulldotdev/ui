---
import type { ImageMetadata } from "astro"
import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"
import BlockPlaceholder from "@/components/block-placeholder.astro"

type BlockAction = {
  label: string
  href: string
  variant?: "default" | "outline" | "ghost" | "secondary"
}

type BlockImage = {
  src: ImageMetadata
  alt: string
}

interface Props {
  props: {
    badge: string
    title: string
    description: string
    meta: {
      publishedLabel: string
      publishedValue: string
      readingTimeLabel: string
      readingTimeValue: string
      action: BlockAction
    }
    image: BlockImage
    quote: string
    points: {
      kicker: string
      title: string
      description: string
    }[]
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="grid gap-8 lg:grid-cols-[14rem_minmax(0,1fr)] lg:gap-12">
    <aside class="flex flex-col gap-5 lg:sticky lg:top-24 lg:self-start">
      <Badge variant="secondary">{props.badge}</Badge>
      <div>
        <p class="text-sm font-medium">{props.meta.publishedLabel}</p>
        <p class="text-muted-foreground text-sm">{props.meta.publishedValue}</p>
      </div>
      <div>
        <p class="text-sm font-medium">{props.meta.readingTimeLabel}</p>
        <p class="text-muted-foreground text-sm">{props.meta.readingTimeValue}</p>
      </div>
      <Button as="a" href={props.meta.action.href} variant={props.meta.action.variant}>
        {props.meta.action.label}
      </Button>
    </aside>

    <div class="flex flex-col gap-8">
      <div class="flex flex-col gap-4">
        <h2 class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{props.title}</h2>
        <p class="text-muted-foreground max-w-2xl text-lg leading-relaxed">{props.description}</p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <BlockPlaceholder image={props.image} class="aspect-[4/3] rounded-2xl border" />
        <Card class="justify-center">
          <CardHeader>
            <CardTitle class="text-2xl leading-tight">{props.quote}</CardTitle>
          </CardHeader>
        </Card>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {props.points.map((point) => (
          <Card>
            <CardContent class="flex items-center gap-3 p-6">
              <div class="bg-primary/10 text-primary flex size-10 items-center justify-center rounded-full font-medium">
                {point.kicker}
              </div>
              <div>
                <p class="font-medium">{point.title}</p>
                <p class="text-muted-foreground text-sm">{point.description}</p>
              </div>
            </CardContent>
          </Card>
        ))}
      </div>
    </div>
  </SectionContent>
</Section>
