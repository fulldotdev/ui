---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar"
import { Badge } from "@/components/ui/badge"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  badge?: string
  title: string
  description: string
  author: {
    image?: ImageMetadata
    initials: string
    name: string
    date: string
    readingTime: string
  }
  image: {
    src: ImageMetadata
    alt: string
  }
  quote?: string
  points?: {
    title: string
    description: string
  }[]
}

const {
  badge,
  title,
  description,
  author,
  image,
  quote,
  points = [],
} = Astro.props
---

<Section>
  <SectionContainer class="mx-auto max-w-2xl items-center gap-8 text-center">
    <div class="mx-auto flex w-full max-w-2xl flex-col items-center gap-6">
      {badge && <Badge variant="secondary">{badge}</Badge>}
      <div class="flex flex-col gap-4">
        <h1
          class="text-4xl leading-tight font-semibold tracking-tight text-balance sm:text-5xl"
        >
          {title}
        </h1>
        <p class="text-muted-foreground text-lg leading-8 text-balance">
          {description}
        </p>
      </div>
      <div class="flex items-center gap-3">
        <Avatar size="lg">
          <AvatarImage src={author.image} alt={author.name} />
          <AvatarFallback>{author.initials}</AvatarFallback>
        </Avatar>
        <div class="flex flex-col text-left">
          <p class="text-sm font-medium">
            {author.name}
            <span class="text-muted-foreground font-normal">
              &middot; {author.date}
            </span>
          </p>
          <p class="text-muted-foreground text-xs">{author.readingTime}</p>
        </div>
      </div>
    </div>

    <Image
      src={image.src}
      alt={image.alt}
      class="aspect-[16/10] w-full rounded-xl object-cover"
      widths={[640, 960]}
      sizes="(min-width: 42rem) 42rem, 100vw"
    />

    <article
      class="mx-auto flex w-full max-w-2xl flex-col gap-6 text-left text-base leading-8"
    >
      {quote && <p class="text-xl leading-8 font-medium">{quote}</p>}
      {
        points.map((point) => (
          <section class="flex flex-col gap-2">
            <p class="text-sm font-medium">{point.title}</p>
            <p class="text-muted-foreground">{point.description}</p>
          </section>
        ))
      }
    </article>
  </SectionContainer>
</Section>
