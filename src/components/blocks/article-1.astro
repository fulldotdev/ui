---
import type { ImageMetadata } from "astro"
import { Avatar, AvatarFallback } from "@/components/ui/avatar"
import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"
import BlockPlaceholder from "@/components/block-placeholder.astro"

type BlockAction = {
  label: string
  href: string
  variant?: "default" | "outline" | "ghost" | "secondary"
}

type BlockImage = {
  src: ImageMetadata
  alt: string
}

interface Props {
  props: {
    badge: string
    title: string
    description: string
    author: {
      initials: string
      name: string
      meta: string
    }
    image: BlockImage
    body: string[]
    aside: {
      title: string
      description: string
      sections: {
        label: string
        text: string
      }[]
      action: BlockAction
    }
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="gap-10">
    <div class="mx-auto flex max-w-3xl flex-col gap-6 text-center">
      <Badge variant="outline" class="mx-auto">{props.badge}</Badge>
      <h1 class="text-4xl font-semibold tracking-tight text-balance sm:text-5xl">{props.title}</h1>
      <p class="text-muted-foreground text-lg leading-relaxed text-balance">{props.description}</p>
      <div class="mx-auto flex items-center gap-3 text-sm">
        <Avatar>
          <AvatarFallback>{props.author.initials}</AvatarFallback>
        </Avatar>
        <div class="text-left">
          <p class="font-medium">{props.author.name}</p>
          <p class="text-muted-foreground">{props.author.meta}</p>
        </div>
      </div>
    </div>

    <BlockPlaceholder image={props.image} class="aspect-[16/8] w-full rounded-2xl border" />

    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_18rem]">
      <div class="flex flex-col gap-6 text-base leading-8">
        {props.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <Card>
        <CardHeader>
          <CardTitle>{props.aside.title}</CardTitle>
          <CardDescription>{props.aside.description}</CardDescription>
        </CardHeader>
        <CardContent class="flex flex-col gap-4 text-sm leading-6">
          {props.aside.sections.map((section) => (
            <div>
              <p class="font-medium">{section.label}</p>
              <p class="text-muted-foreground">{section.text}</p>
            </div>
          ))}
          <Button as="a" href={props.aside.action.href} variant={props.aside.action.variant}>
            {props.aside.action.label}
          </Button>
        </CardContent>
      </Card>
    </div>
  </SectionContent>
</Section>
