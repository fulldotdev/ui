---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { cn } from "@/lib/utils"
import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar"
import { Badge } from "@/components/ui/badge"
import { Section, SectionContainer } from "@/components/ui/section"

type Props = {
  class?: string
  badge?: string
  title: string
  description: string
  author: {
    image?: ImageMetadata
    initials: string
    name: string
    date: string
  }
  image: {
    src: ImageMetadata
    alt: string
  }
}

const {
  class: className,
  badge,
  title,
  description,
  author,
  image,
} = Astro.props
---

<Section class={cn("", className)}>
  <SectionContainer class="mx-auto max-w-2xl gap-8">
    <div class="mx-auto flex w-full max-w-2xl flex-col gap-6">
      {
        badge && (
          <Badge variant="secondary" class="w-fit">
            {badge}
          </Badge>
        )
      }
      <div class="flex flex-col gap-4">
        <h1
          class="text-4xl leading-tight font-semibold tracking-tight text-balance sm:text-5xl"
        >
          {title}
        </h1>
        <p class="text-muted-foreground text-lg leading-8 text-balance">
          {description}
        </p>
      </div>
      <div class="flex items-center gap-3">
        <Avatar size="lg">
          <AvatarImage src={author.image} alt={author.name} />
          <AvatarFallback>{author.initials}</AvatarFallback>
        </Avatar>
        <div class="flex flex-col">
          <p class="text-sm font-medium">{author.name}</p>
          <p class="text-muted-foreground text-xs">{author.date}</p>
        </div>
      </div>
    </div>

    <Image
      src={image.src}
      alt={image.alt}
      class="aspect-16/10 w-full rounded-xl object-cover"
      widths={[640, 960]}
      sizes="(min-width: 42rem) 42rem, 100vw"
    />

    <article
      class="mx-auto flex w-full max-w-2xl flex-col gap-6 text-base leading-8"
    >
      <slot />
    </article>
  </SectionContainer>
</Section>
