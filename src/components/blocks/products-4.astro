---
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"

type Item = {
  title: string
  description: string
}

interface Props {
  props: {
    items: Item[]
  }
}

const { props } = Astro.props
---

<Section class="rounded-3xl border bg-muted/10">
  <SectionContent class="gap-8 p-8 sm:p-10">
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {props.items.map((item) => (
        <Card>
          <CardHeader><CardTitle class="text-lg">{item.title}</CardTitle></CardHeader>
          <CardContent class="text-muted-foreground text-sm leading-6">{item.description}</CardContent>
        </Card>
      ))}
    </div>
  </SectionContent>
</Section>
