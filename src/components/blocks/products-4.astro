---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { cn } from "@/lib/utils"
import { Button } from "@/components/ui/button"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card"
import { Price, PriceUnit, PriceValue } from "@/components/ui/price"
import { Section, SectionContainer } from "@/components/ui/section"

type Props = {
  class?: string
  title: string
  description: string
  buttons: {
    label: string
    href: string
    variant?: "default" | "outline" | "secondary" | "ghost"
  }[]
  products: {
    image: {
      src: ImageMetadata
      alt: string
    }
    title: string
    description: string
    price: {
      value: number
      currency: string
      unit: string
    }
  }[]
}

const { class: className, title, description, buttons, products } = Astro.props
---

<Section class={cn("", className)}>
  <SectionContainer class="gap-8">
    <div
      class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between"
    >
      <div class="max-w-2xl">
        <h2
          class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
        >
          {title}
        </h2>
        <p class="text-muted-foreground mt-3 text-lg leading-8">
          {description}
        </p>
      </div>
      <div class="flex shrink-0 flex-wrap gap-3">
        {
          buttons.map(({ href, label, ...button }) => (
            <Button as="a" href={href} variant={button.variant}>
              {label}
            </Button>
          ))
        }
      </div>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        products.map((product) => (
          <Card>
            <Image
              src={product.image.src}
              alt={product.image.alt}
              class="aspect-4/3 w-full object-cover"
            />
            <CardHeader>
              <CardTitle>{product.title}</CardTitle>
              <CardDescription>{product.description}</CardDescription>
            </CardHeader>
            <CardContent>
              <Price>
                <PriceValue
                  price={product.price.value}
                  currency={product.price.currency}
                />
                <PriceUnit>{product.price.unit}</PriceUnit>
              </Price>
            </CardContent>
          </Card>
        ))
      }
    </div>
  </SectionContainer>
</Section>
