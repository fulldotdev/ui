---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { cn } from "@/lib/utils"
import { Section, SectionContainer } from "@/components/ui/section"

type Props = {
  class?: string
  title: string
  description: string
  features: {
    title: string
    description: string
    image: {
      src: ImageMetadata
      alt: string
    }
  }[]
}

const { class: className, title, description, features } = Astro.props
---

<Section class={cn("", className)}>
  <SectionContainer class="items-center gap-6 text-center">
    <div class="flex max-w-2xl flex-col items-center gap-4">
      <h2
        class="text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
      >
        {title}
      </h2>
      <p
        class="text-muted-foreground max-w-2xl text-lg leading-relaxed text-balance"
      >
        {description}
      </p>
    </div>
  </SectionContainer>
  <SectionContainer>
    <div class="grid gap-6 sm:grid-cols-2">
      {
        features.map((feature) => (
          <div class="group/feature hover:bg-muted/40 flex items-center gap-5 rounded-xl border p-4 transition-colors">
            <Image
              src={feature.image.src}
              alt={feature.image.alt}
              class="size-20 shrink-0 rounded-lg object-cover"
              widths={[160, 320]}
              sizes="80px"
            />
            <div class="flex flex-col gap-1.5">
              <h3 class="text-foreground text-base font-medium">
                {feature.title}
              </h3>
              <p class="text-muted-foreground text-sm leading-relaxed">
                {feature.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </SectionContainer>
</Section>
