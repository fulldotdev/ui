---
import QuoteIcon from "@lucide/astro/icons/quote"

import { Avatar, AvatarFallback } from "@/components/ui/avatar"
import { Card, CardContent } from "@/components/ui/card"
import { Rating } from "@/components/ui/rating"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  title?: string
  description?: string
  items: {
    rating: number
    quote: string
    initials: string
    name: string
    role: string
  }[]
}

const { title, description, items } = Astro.props
---

<Section>
  {
    (title || description) && (
      <SectionContainer class="items-center gap-4 text-center">
        {title && (
          <h2 class="text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl">
            {title}
          </h2>
        )}
        {description && (
          <p class="text-muted-foreground max-w-2xl text-lg leading-relaxed text-balance">
            {description}
          </p>
        )}
      </SectionContainer>
    )
  }
  <SectionContainer>
    <div class="grid gap-6 md:grid-cols-3">
      {
        items.map((item) => (
          <Card>
            <CardContent class="flex flex-col gap-4">
              <div class="flex items-center justify-between">
                <Rating value={item.rating} />
                <QuoteIcon class="text-muted-foreground/20 size-6" />
              </div>
              <p class="text-muted-foreground text-sm leading-relaxed">
                {item.quote}
              </p>
              <div class="flex items-center gap-3 pt-2">
                <Avatar size="lg">
                  <AvatarFallback>{item.initials}</AvatarFallback>
                </Avatar>
                <div>
                  <p class="text-foreground text-sm font-medium">{item.name}</p>
                  <p class="text-muted-foreground text-xs">{item.role}</p>
                </div>
              </div>
            </CardContent>
          </Card>
        ))
      }
    </div>
  </SectionContainer>
</Section>
