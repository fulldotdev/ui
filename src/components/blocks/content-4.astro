---
import { Badge } from "@/components/ui/badge"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    badge: string
    title: string
    description: string
    comparison: {
      first: {
        title: string
        description: string
      }
      second: {
        title: string
        description: string
      }
    }
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="gap-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <Badge variant="outline" class="w-fit">{props.badge}</Badge>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{props.title}</h2>
      </div>
      <p class="text-muted-foreground max-w-md text-sm leading-6">{props.description}</p>
    </div>
    <div class="grid gap-4 lg:grid-cols-2">
      <Card>
        <CardHeader><CardTitle>{props.comparison.first.title}</CardTitle></CardHeader>
        <CardContent class="text-muted-foreground text-sm leading-7">{props.comparison.first.description}</CardContent>
      </Card>
      <Card>
        <CardHeader><CardTitle>{props.comparison.second.title}</CardTitle></CardHeader>
        <CardContent class="text-muted-foreground text-sm leading-7">{props.comparison.second.description}</CardContent>
      </Card>
    </div>
  </SectionContent>
</Section>
