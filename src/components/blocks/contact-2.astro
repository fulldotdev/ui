---
import LayoutGridIcon from "@lucide/astro/icons/layout-grid"

import { Button } from "@/components/ui/button"
import {
  Field,
  FieldGroup,
  FieldLabel,
  FieldLegend,
  FieldSet,
} from "@/components/ui/field"
import { Input } from "@/components/ui/input"
import { Section, SectionContainer } from "@/components/ui/section"
import { Textarea } from "@/components/ui/textarea"

interface Props {
  title: string
  description: string
  items: {
    icon: typeof LayoutGridIcon
    title: string
    description: string
  }[]
  form: {
    title: string
    legend: string
    nameLabel: string
    namePlaceholder: string
    emailLabel: string
    emailPlaceholder: string
    messageLabel: string
    messagePlaceholder: string
    actionLabel: string
  }
}

const { title, description, items, form } = Astro.props
---

<Section>
  <SectionContainer
    class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-start"
  >
    <div class="flex flex-col gap-6">
      <div class="flex flex-col gap-4">
        <h2
          class="text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
        >
          {title}
        </h2>
        <p class="text-muted-foreground max-w-xl text-base leading-relaxed">
          {description}
        </p>
      </div>
      <div class="rounded-xl border p-6">
        <div class="mb-6">
          <h3 class="text-lg font-medium">{form.title}</h3>
        </div>
        <FieldSet>
          <FieldLegend class="sr-only">{form.legend}</FieldLegend>
          <FieldGroup>
            <div class="grid gap-4 md:grid-cols-2">
              <Field>
                <FieldLabel for="contact-name-2">{form.nameLabel}</FieldLabel>
                <Input id="contact-name-2" placeholder={form.namePlaceholder} />
              </Field>
              <Field>
                <FieldLabel for="contact-email-2">{form.emailLabel}</FieldLabel>
                <Input
                  id="contact-email-2"
                  type="email"
                  placeholder={form.emailPlaceholder}
                />
              </Field>
            </div>
            <Field>
              <FieldLabel for="contact-message-2"
                >{form.messageLabel}</FieldLabel
              >
              <Textarea
                id="contact-message-2"
                rows={5}
                placeholder={form.messagePlaceholder}
              />
            </Field>
            <Button size="lg" class="w-full">{form.actionLabel}</Button>
          </FieldGroup>
        </FieldSet>
      </div>
    </div>

    <div class="flex flex-col gap-3">
      {
        items.map((item) => {
          const Icon = item.icon
          return (
            <div class="flex gap-4 rounded-xl border p-4">
              <div class="bg-primary/10 text-primary flex size-10 shrink-0 items-center justify-center rounded-lg">
                <Icon class="size-5" />
              </div>
              <div class="flex flex-col gap-1">
                <p class="text-foreground text-sm font-medium">{item.title}</p>
                <p class="text-muted-foreground text-sm leading-relaxed">
                  {item.description}
                </p>
              </div>
            </div>
          )
        })
      }
    </div>
  </SectionContainer>
</Section>
