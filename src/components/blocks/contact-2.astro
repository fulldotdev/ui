---
import { Button } from "@/components/ui/button"
import { Card, CardContent } from "@/components/ui/card"
import { Field, FieldGroup, FieldLabel, FieldSet, FieldLegend } from "@/components/ui/field"
import { Input } from "@/components/ui/input"
import { Section, SectionContent } from "@/components/ui/section"
import { Textarea } from "@/components/ui/textarea"

interface Props {
  props: {
    title: string
    description: string
    form: {
      legend: string
      nameLabel: string
      namePlaceholder: string
      companyLabel: string
      companyPlaceholder: string
      emailLabel: string
      emailPlaceholder: string
      messageLabel: string
      messagePlaceholder: string
      note: string
      actionLabel: string
    }
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="gap-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{props.title}</h2>
      <p class="text-muted-foreground mt-4 text-base leading-7">{props.description}</p>
    </div>

    <Card class="mx-auto w-full max-w-3xl">
      <CardContent class="p-6 sm:p-8">
        <FieldSet>
          <FieldLegend>{props.form.legend}</FieldLegend>
          <FieldGroup>
            <div class="grid gap-4 md:grid-cols-2">
              <Field>
                <FieldLabel for="contact-name-2">{props.form.nameLabel}</FieldLabel>
                <Input id="contact-name-2" placeholder={props.form.namePlaceholder} />
              </Field>
              <Field>
                <FieldLabel for="contact-company-2">{props.form.companyLabel}</FieldLabel>
                <Input id="contact-company-2" placeholder={props.form.companyPlaceholder} />
              </Field>
            </div>
            <Field>
              <FieldLabel for="contact-email-2">{props.form.emailLabel}</FieldLabel>
              <Input id="contact-email-2" type="email" placeholder={props.form.emailPlaceholder} />
            </Field>
            <Field>
              <FieldLabel for="contact-message-2">{props.form.messageLabel}</FieldLabel>
              <Textarea id="contact-message-2" rows={6} placeholder={props.form.messagePlaceholder} />
            </Field>
            <div class="flex flex-wrap items-center justify-between gap-3">
              <p class="text-muted-foreground text-sm">{props.form.note}</p>
              <Button>{props.form.actionLabel}</Button>
            </div>
          </FieldGroup>
        </FieldSet>
      </CardContent>
    </Card>
  </SectionContent>
</Section>
