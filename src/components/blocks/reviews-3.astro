---
import { Badge } from "@/components/ui/badge"
import { Card, CardContent } from "@/components/ui/card"
import { Rating } from "@/components/ui/rating"
import { Section, SectionContent } from "@/components/ui/section"

interface Props {
  props: {
    badge: string
    title: string
    items: {
      rating: number
      team: string
      description: string
    }[]
  }
}

const { props } = Astro.props
---

<Section class="rounded-3xl border bg-muted/10">
  <SectionContent class="gap-8 p-8 sm:p-10">
    <div class="max-w-2xl">
      <Badge variant="outline">{props.badge}</Badge>
      <h2 class="mt-4 text-3xl font-semibold tracking-tight text-balance sm:text-4xl">{props.title}</h2>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {props.items.map((item) => (
        <Card>
          <CardContent class="flex flex-col gap-3 p-5">
            <Rating value={item.rating} />
            <p class="font-medium">{item.team}</p>
            <p class="text-muted-foreground text-sm leading-6">{item.description}</p>
          </CardContent>
        </Card>
      ))}
    </div>
  </SectionContent>
</Section>
