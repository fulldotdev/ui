---
import type { ImageMetadata } from "astro"

import { cn } from "@/lib/utils"
import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar"
import {
  Carousel,
  CarouselContent,
  CarouselItem,
  CarouselNext,
  CarouselPrevious,
} from "@/components/ui/carousel"
import { Icon } from "@/components/ui/icon"
import { Rating } from "@/components/ui/rating"
import { Section, SectionContainer } from "@/components/ui/section"

type Props = {
  class?: string
  title?: string
  description?: string
  reviews: {
    rating: number
    quote: string
    image?: ImageMetadata
    initials: string
    name: string
    role: string
  }[]
}

const { class: className, title, description, reviews } = Astro.props
---

<Section class={cn("", className)}>
  {
    (title || description) && (
      <SectionContainer class="items-center gap-4 text-center">
        {title && (
          <h2 class="text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl">
            {title}
          </h2>
        )}
        {description && (
          <p class="text-muted-foreground max-w-2xl text-lg leading-relaxed text-balance">
            {description}
          </p>
        )}
      </SectionContainer>
    )
  }
  <SectionContainer>
    <Carousel opts={{ loop: true, align: "center" }} class="mx-auto max-w-3xl">
      <CarouselContent>
        {
          reviews.map((item) => (
            <CarouselItem>
              <div class="flex flex-col items-center gap-6 px-4 py-8 text-center">
                <Icon name="quote" class="text-primary size-10" />
                <Rating value={item.rating} />
                <blockquote class="text-foreground text-xl leading-relaxed font-medium text-balance sm:text-2xl">
                  {item.quote}
                </blockquote>
                <div class="flex items-center gap-3 pt-2">
                  <Avatar size="lg">
                    <AvatarImage src={item.image} alt={item.name} />
                    <AvatarFallback>{item.initials}</AvatarFallback>
                  </Avatar>
                  <div class="text-left">
                    <p class="text-foreground text-sm font-medium">
                      {item.name}
                    </p>
                    <p class="text-muted-foreground text-xs">{item.role}</p>
                  </div>
                </div>
              </div>
            </CarouselItem>
          ))
        }
      </CarouselContent>
      <CarouselPrevious />
      <CarouselNext />
    </Carousel>
  </SectionContainer>
</Section>
