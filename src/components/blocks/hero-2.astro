---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { Avatar, AvatarFallback, AvatarGroup } from "@/components/ui/avatar"
import { Button } from "@/components/ui/button"
import { Rating } from "@/components/ui/rating"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  title: string
  description: string
  actions: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
  socialProof: {
    avatars: string[]
    rating: number
    text: string
  }
  image: {
    src: ImageMetadata
    alt: string
  }
}

const { title, description, actions, socialProof, image } = Astro.props
---

<Section>
  <SectionContainer class="items-center gap-8 text-center">
    <div class="flex flex-col items-center gap-3">
      <AvatarGroup>
        {
          socialProof.avatars.map((initials) => (
            <Avatar class="ring-background size-11 ring">
              <AvatarFallback>{initials}</AvatarFallback>
            </Avatar>
          ))
        }
      </AvatarGroup>
      <div class="flex items-center gap-2">
        <Rating value={socialProof.rating} />
        <span class="text-muted-foreground text-sm">{socialProof.text}</span>
      </div>
    </div>
    <h1
      class="text-foreground max-w-4xl text-4xl leading-[1.1] font-semibold tracking-tight text-balance sm:text-5xl lg:text-6xl"
    >
      {title}
    </h1>
    <p
      class="text-muted-foreground max-w-2xl text-lg leading-relaxed text-balance"
    >
      {description}
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      {
        actions.map((action, i) => (
          <Button
            as="a"
            href={action.href}
            size="lg"
            variant={action.variant ?? (i === 0 ? "default" : "secondary")}
          >
            {action.label}
          </Button>
        ))
      }
    </div>
  </SectionContainer>
  <SectionContainer>
    <Image
      src={image.src}
      alt={image.alt}
      class="aspect-video w-full rounded-xl border object-cover"
      widths={[640, 960, 1280, 1536]}
      sizes="(min-width: 80rem) 80rem, 100vw"
      loading="eager"
    />
  </SectionContainer>
</Section>
