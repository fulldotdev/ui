---
import type { ImageMetadata } from "astro"
import { Button } from "@/components/ui/button"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"
import BlockPlaceholder from "@/components/block-placeholder.astro"

type BlockAction = {
  label: string
  href: string
  variant?: "default" | "outline" | "ghost" | "secondary"
}

type BlockImage = {
  src: ImageMetadata
  alt: string
}

interface Props {
  props: {
    items: {
      title: string
      description: string
      image: BlockImage
      action: BlockAction
    }[]
  }
}

const { props } = Astro.props
---

<Section>
  <SectionContent class="grid gap-4 md:grid-cols-2">
    {props.items.map((item) => (
      <Card>
        <CardHeader><CardTitle>{item.title}</CardTitle></CardHeader>
        <CardContent class="flex flex-col gap-4">
          <BlockPlaceholder image={item.image} class="aspect-[16/10] rounded-2xl border" />
          <p class="text-muted-foreground text-sm leading-6">{item.description}</p>
          <Button as="a" href={item.action.href} variant={item.action.variant}>{item.action.label}</Button>
        </CardContent>
      </Card>
    ))}
  </SectionContent>
</Section>
