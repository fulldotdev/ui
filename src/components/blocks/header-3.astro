---
import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import { Header, HeaderGroup } from "@/components/ui/header"
import { Logo, LogoText } from "@/components/ui/logo"

type BlockAction = {
  label: string
  href: string
  variant?: "default" | "outline" | "ghost" | "secondary"
}

interface Props {
  props: {
    announcement: string
    badge: string
    brandName: string
    brandHref: string
    actions: [BlockAction, BlockAction]
  }
}

const { props } = Astro.props
---

<div class="flex flex-col gap-3">
  <div class="rounded-xl border bg-muted/20 px-4 py-2 text-center text-sm">
    {props.announcement}
  </div>
  <Header>
    <HeaderGroup>
      <Logo href={props.brandHref}><LogoText>{props.brandName}</LogoText></Logo>
    </HeaderGroup>
    <HeaderGroup class="ml-auto justify-end">
      <Badge variant="outline">{props.badge}</Badge>
      {
        props.actions.map((action) => (
          <Button as="a" href={action.href} size="sm" variant={action.variant}>
            {action.label}
          </Button>
        ))
      }
    </HeaderGroup>
  </Header>
</div>
