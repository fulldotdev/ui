---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import { Price, PriceUnit, PriceValue } from "@/components/ui/price"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  badge: string
  title: string
  description: string
  image: {
    src: ImageMetadata
    alt: string
  }
  price: {
    value: number
    currency: string
    unit: string
  }
  note: string
  actions: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
}

const { badge, title, description, image, price, note, actions } = Astro.props
---

<Section>
  <SectionContainer class="grid gap-8 lg:grid-cols-2 lg:items-center">
    <Image
      src={image.src}
      alt={image.alt}
      class="aspect-[16/11] rounded-lg object-cover"
    />
    <div class="flex flex-col gap-5">
      <Badge variant="secondary" class="w-fit">{badge}</Badge>
      <h1
        class="text-4xl font-semibold tracking-tight text-balance sm:text-5xl"
      >
        {title}
      </h1>
      <p class="text-muted-foreground text-lg leading-8">{description}</p>
      <Price>
        <PriceValue price={price.value} currency={price.currency} />
        <PriceUnit>{price.unit}</PriceUnit>
      </Price>
      <p class="border-y py-4 text-sm leading-7">{note}</p>
      <div class="flex flex-wrap gap-3">
        {
          actions.map((action) => (
            <Button as="a" href={action.href} variant={action.variant}>
              {action.label}
            </Button>
          ))
        }
      </div>
    </div>
  </SectionContainer>
</Section>
