---
import LayoutGridIcon from "@lucide/astro/icons/layout-grid"

import { Button } from "@/components/ui/button"
import { Section, SectionContainer } from "@/components/ui/section"

interface Props {
  title: string
  description: string
  actions?: {
    label: string
    href: string
    variant?: "default" | "outline" | "ghost" | "secondary"
  }[]
  items: {
    title: string
    description: string
    icon: typeof LayoutGridIcon
  }[]
}

const { title, description, actions, items } = Astro.props
---

<Section variant="floating">
  <SectionContainer class="items-center gap-6 text-center">
    <div class="flex max-w-2xl flex-col items-center gap-4">
      <h2
        class="text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
      >
        {title}
      </h2>
      <p
        class="text-muted-foreground max-w-2xl text-lg leading-relaxed text-balance"
      >
        {description}
      </p>
    </div>
    {
      actions?.length ? (
        <div class="flex flex-wrap justify-center gap-3">
          {actions.map((action, i) => (
            <Button
              as="a"
              href={action.href}
              variant={action.variant ?? (i === 0 ? "default" : "outline")}
            >
              {action.label}
            </Button>
          ))}
        </div>
      ) : null
    }
  </SectionContainer>
  <SectionContainer>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        items.map((item) => {
          const Icon = item.icon
          return (
            <div class="group/feature flex flex-col items-center gap-4 text-center">
              <div class="bg-primary/5 text-primary border-primary/20 flex size-12 items-center justify-center rounded-xl border">
                <Icon class="size-5" />
              </div>
              <h3 class="text-foreground text-base font-medium text-balance">
                {item.title}
              </h3>
              <p class="text-muted-foreground text-sm leading-relaxed text-balance">
                {item.description}
              </p>
            </div>
          )
        })
      }
    </div>
  </SectionContainer>
</Section>
