---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { cn } from "@/lib/utils"
import { Avatar, AvatarFallback, AvatarImage } from "@/components/ui/avatar"
import { Badge } from "@/components/ui/badge"
import { Section, SectionContainer } from "@/components/ui/section"

type Props = {
  class?: string
  badge?: string
  title: string
  articles: {
    image: {
      src: ImageMetadata
      alt: string
    }
    category: string
    title: string
    description: string
    href?: string
    author: {
      image?: ImageMetadata
      initials: string
      name: string
      date: string
    }
  }[]
}

const { class: className, badge, title, articles } = Astro.props
---

<Section class={cn("", className)}>
  <SectionContainer class="gap-8">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div class="flex flex-col gap-4">
        {
          badge && (
            <Badge variant="secondary" class="w-fit">
              {badge}
            </Badge>
          )
        }
        <h2
          class="text-3xl font-semibold tracking-tight text-balance sm:text-4xl"
        >
          {title}
        </h2>
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        articles.map((article) => (
          <a
            href={article.href ?? "#"}
            class="group bg-muted/50 hover:bg-muted focus-visible:ring-ring/50 flex h-full flex-col gap-4 rounded-xl p-4 transition-colors focus-visible:ring-2 focus-visible:outline-none"
          >
            <Image
              src={article.image.src}
              alt={article.image.alt}
              class="-mx-4 -mt-4 aspect-[16/9] w-[calc(100%+2rem)] max-w-none rounded-lg object-cover transition-opacity group-hover:opacity-85"
              widths={[480, 720]}
              sizes="(min-width: 64rem) 18rem, (min-width: 48rem) 50vw, 100vw"
            />
            <div class="flex flex-col gap-2">
              <p class="text-muted-foreground text-sm font-medium">
                {article.category}
              </p>
              <h3 class="text-foreground line-clamp-2 text-lg leading-snug font-semibold">
                {article.title}
              </h3>
              <p class="text-muted-foreground line-clamp-2 text-sm leading-6">
                {article.description}
              </p>
            </div>
            <div class="mt-auto flex items-center gap-3">
              <Avatar>
                <AvatarImage
                  src={article.author.image}
                  alt={article.author.name}
                />
                <AvatarFallback>{article.author.initials}</AvatarFallback>
              </Avatar>
              <div class="flex flex-col">
                <p class="text-sm font-medium">{article.author.name}</p>
                <p class="text-muted-foreground text-xs">
                  {article.author.date}
                </p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </SectionContainer>
</Section>
