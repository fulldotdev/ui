---
import type { ImageMetadata } from "astro"
import { Badge } from "@/components/ui/badge"
import { Card, CardContent } from "@/components/ui/card"
import { Section, SectionContent } from "@/components/ui/section"
import BlockPlaceholder from "@/components/block-placeholder.astro"

type BlockImage = {
  src: ImageMetadata
  alt: string
}

interface Props {
  props: {
    stories: {
      image: BlockImage
      tag: string
      title: string
      description: string
      meta: string
    }[]
  }
}

const { props } = Astro.props
---

  <Section>
  <SectionContent class="gap-8">
    <div class="grid gap-3">
      {props.stories.map((story) => (
        <Card>
          <CardContent class="grid gap-4 p-5 md:grid-cols-[12rem_minmax(0,1fr)_10rem] md:items-center">
            <BlockPlaceholder image={story.image} class="aspect-[3/2] rounded-xl border" />
            <div class="flex flex-col gap-2">
              <Badge variant="outline" class="w-fit">{story.tag}</Badge>
              <h3 class="text-xl font-medium leading-snug">{story.title}</h3>
              <p class="text-muted-foreground text-sm leading-6">{story.description}</p>
            </div>
            <p class="text-muted-foreground text-sm md:text-right">{story.meta}</p>
          </CardContent>
        </Card>
      ))}
    </div>
  </SectionContent>
</Section>
