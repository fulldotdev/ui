---
import type { ImageMetadata } from "astro"
import { Image } from "astro:assets"

import { cn } from "@/lib/utils"

type BlockImage = {
  src: ImageMetadata
  alt: string
}

interface Props {
  image: BlockImage
  class?: string
}

const { class: className, image } = Astro.props
---

<Image
  src={image.src}
  alt={image.alt}
  class={cn("w-full object-cover", className)}
/>
