---
import type { GlobalSchema } from "@/schemas/global"
import type { BaseLayoutSchema } from "@/schemas/layouts/base"
import { Button } from "@/components/ui/button"
import {
  HeaderActions,
  Header,
  HeaderContent,
  HeaderGroup,
  HeaderInset,
  HeaderProvider,
} from "@/components/ui/header"
import { Layout, LayoutBody, LayoutHead } from "@/components/ui/layout"
import { Logo, LogoImage, LogoText } from "@/components/ui/logo"
import {
  NavigationMenu,
  NavigationMenuItem,
  NavigationMenuLink,
  NavigationMenuList,
  navigationMenuTriggerStyle,
} from "@/components/ui/navigation-menu"

interface Props {
  global?: GlobalSchema
  page: BaseLayoutSchema
  hideHeader?: boolean
  hideFooter?: boolean
  variant?: "default" | "floating" | "inset"
}

const {
  global,
  page,
  hideHeader = false,
  hideFooter = false,
  variant = "default",
} = Astro.props

const desktopMenuItemClass = navigationMenuTriggerStyle({
  class:
    "text-muted-foreground hover:text-foreground focus:text-foreground data-[active=true]:text-foreground h-8 bg-transparent px-3 py-0 hover:bg-background/80 focus:bg-background/80 data-[active=true]:bg-background/70 data-open:bg-background/70 data-open:hover:bg-background/80",
})
---

<Layout>
  <LayoutHead name={global?.name} {...page.seo} />
  <LayoutBody class={variant === "inset" ? "bg-muted" : undefined}>
    <HeaderProvider>
      {
        !hideHeader && (
          <Header container="full" sticky="never" variant={variant}>
            <HeaderGroup class="shrink-0">
              <Logo href="/">
                <LogoImage
                  src={global?.logo.dark}
                  alt={`${global?.name} logo`}
                  class="h-6 dark:hidden [&:is([data-theme=dark]_&)]:hidden"
                />
                <LogoImage
                  src={global?.logo.light}
                  alt={`${global?.name} logo`}
                  class="hidden h-6 dark:block [&:is([data-theme=dark]_&)]:block"
                />
                <LogoText class="text-lg tracking-tight">
                  {global?.name}
                </LogoText>
              </Logo>
            </HeaderGroup>
            <HeaderContent class="hidden min-w-0 flex-1 justify-start md:flex">
              <NavigationMenu class="max-w-none justify-start">
                <NavigationMenuList class="flex flex-none list-none items-center justify-start gap-0">
                  {global?.header.links.map((link, index) => (
                    <NavigationMenuItem value={`header-link-${index}`}>
                      <NavigationMenuLink
                        href={link.href}
                        class={desktopMenuItemClass}
                      >
                        {link.text}
                      </NavigationMenuLink>
                    </NavigationMenuItem>
                  ))}
                </NavigationMenuList>
              </NavigationMenu>
            </HeaderContent>
            <HeaderGroup side="end" class="hidden shrink-0 md:flex">
              <HeaderActions class="justify-end">
                {global?.header.buttons.map((button, index) => (
                  <Button
                    as="a"
                    href={button.href}
                    variant={button.variant ?? (index === 0 ? "default" : "ghost")}
                    size="sm"
                  >
                    {button.text}
                  </Button>
                ))}
              </HeaderActions>
            </HeaderGroup>
          </Header>
        )
      }
      <HeaderInset>
        <slot />
      </HeaderInset>
      {
        !hideFooter && (
          <footer class="px-6 py-8">
            <p class="text-muted-foreground mx-auto max-w-(--container) text-sm">
              {global?.name}
            </p>
          </footer>
        )
      }
    </HeaderProvider>
  </LayoutBody>
</Layout>
