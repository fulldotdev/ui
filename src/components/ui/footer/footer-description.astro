---
import type { HTMLAttributes } from "astro/types"
import { cva, type VariantProps } from "class-variance-authority"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"p"> & VariantProps<typeof variants>

const variants = cva("text-muted-foreground text-sm", {
  variants: {
    size: {
      lg: "text-base",
      default: "text-sm",
      sm: "text-xs",
    },
  },
  defaultVariants: {
    size: "default",
  },
})

const { class: className, size, ...props } = Astro.props
---

<p
  data-slot="footer-description"
  class={cn(variants({ size }), className)}
  {...props}
>
  <slot />
</p>
