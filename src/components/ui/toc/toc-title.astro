---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"p"> &
  HTMLAttributes<"h2"> &
  HTMLAttributes<"div"> & {
    as?: "p" | "h2" | "div"
  }

const { as: Tag = "p", class: className, ...props } = Astro.props as Props
---

<Tag
  data-slot="toc-title"
  class={cn("text-sm font-medium tracking-tight", className)}
  {...props}
>
  <slot />
</Tag>
