---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

const HEADER_HEIGHT = "4rem"
const HEADER_INSET_SPACING = "0.5rem"
const HEADER_SHEET_WIDTH = "18rem"
const HEADER_WIDTH = "var(--container, var(--breakpoint-xl))"

type Props = HTMLAttributes<"div">

const { class: className, style, ...props } = Astro.props

const resolvedStyle = [
  `--header-height: ${HEADER_HEIGHT}`,
  `--header-inset-spacing: ${HEADER_INSET_SPACING}`,
  `--header-sheet-width: ${HEADER_SHEET_WIDTH}`,
  `--header-width: ${HEADER_WIDTH}`,
  typeof style === "string" ? style : undefined,
]
  .filter(Boolean)
  .join("; ")
---

<div
  data-slot="header-wrapper"
  style={resolvedStyle}
  class={cn(
    "group/header-wrapper has-data-[variant=floating]:bg-sidebar has-data-[variant=inset]:bg-sidebar flex min-h-svh w-full flex-col",
    className
  )}
  {...props}
>
  <slot />
</div>
