---
import type { ComponentProps } from "astro/types"

import { cn } from "@/lib/utils"
import {
  SheetContent,
  SheetDescription,
  SheetHeader,
  SheetTitle,
} from "@/components/ui/sheet"

type Props = ComponentProps<typeof SheetContent>

const { class: className, side = "right", ...props } = Astro.props
---

<SheetContent
  side={side}
  showCloseButton={false}
  class="bg-sidebar text-sidebar-foreground w-(--header-sheet-width) p-0 md:hidden sm:max-w-(--header-sheet-width)"
  {...props}
>
  <SheetHeader class="sr-only">
    <SheetTitle>Header menu</SheetTitle>
    <SheetDescription>Displays the mobile header navigation.</SheetDescription>
  </SheetHeader>
  <div
    data-slot="header-sheet"
    class={cn("flex h-full w-full flex-col", className)}
  >
    <slot />
  </div>
</SheetContent>
