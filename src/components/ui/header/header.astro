---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"header">

const { class: className, ...props } = Astro.props
---

<header
  class={cn(
    "group/header text-sidebar-foreground relative z-50 flex w-full items-center justify-between gap-8 py-2",
    className
  )}
  data-slot="header"
  {...props}
>
  <slot />
</header>
