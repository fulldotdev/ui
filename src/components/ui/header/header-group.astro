---
import type { HTMLAttributes } from "astro/types"
import { cva, type VariantProps } from "class-variance-authority"

import { cn } from "@/lib/utils"

const variants = cva("flex min-w-0 items-center gap-2", {
  variants: {
    side: {
      start: "",
      center: "mx-auto justify-center",
      end: "ml-auto justify-end",
    },
  },
  defaultVariants: {
    side: "start",
  },
})

interface Props
  extends HTMLAttributes<"div">,
    VariantProps<typeof variants> {}

const { class: className, side, ...props } = Astro.props
---

<div
  data-slot="header-group"
  class={cn(variants({ side }), className)}
  {...props}
>
  <slot />
</div>
