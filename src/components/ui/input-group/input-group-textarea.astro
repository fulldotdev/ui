---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

interface Props extends HTMLAttributes<"textarea"> {}

const { class: className, ...props } = Astro.props
---

<textarea
  data-slot="input-group-control"
  class={cn(
    "min-h-16 w-full flex-1 resize-none border-0 bg-transparent px-2.5 py-2 text-base shadow-none outline-none field-sizing-content focus-visible:ring-0 disabled:cursor-not-allowed disabled:opacity-50 aria-invalid:ring-0 dark:bg-transparent md:text-sm",
    className
  )}
  {...props}
>
</textarea>
