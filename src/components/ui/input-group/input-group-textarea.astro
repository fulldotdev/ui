---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"textarea">

const { class: className, ...props } = Astro.props
---

<textarea
  data-slot="input-group-control"
  class={cn(
    "field-sizing-content min-h-16 w-full flex-1 resize-none border-0 bg-transparent px-2.5 py-2 text-base shadow-none outline-none focus-visible:ring-0 disabled:cursor-not-allowed disabled:opacity-50 aria-invalid:ring-0 md:text-sm dark:bg-transparent",
    className
  )}
  {...props}
>
</textarea>
