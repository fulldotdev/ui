---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"input">

const { class: className, ...props } = Astro.props
---

<input
  data-slot="input-group-control"
  class={cn(
    "file:text-foreground placeholder:text-muted-foreground h-full min-w-0 flex-1 border-0 bg-transparent px-2.5 py-1 text-base shadow-none outline-none file:inline-flex file:h-7 file:border-0 file:bg-transparent file:text-sm file:font-medium focus-visible:ring-0 disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 aria-invalid:ring-0 md:text-sm dark:bg-transparent",
    className
  )}
  {...props}
/>
