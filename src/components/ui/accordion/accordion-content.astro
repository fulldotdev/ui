---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

interface Props extends HTMLAttributes<"div"> {}

const { class: className, ...props } = Astro.props
---

<div
  data-slot="accordion-content"
  class="overflow-hidden text-sm [height:var(--accordion-panel-height)] transition-[height] duration-200 ease-out data-starting-style:h-0 data-ending-style:h-0"
  {...props}
>
  <div data-slot="accordion-content-inner" class={cn("pb-4", className)}>
    <slot />
  </div>
</div>
