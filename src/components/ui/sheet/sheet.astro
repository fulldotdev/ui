---
import type { ComponentProps } from "astro/types"

import Dialog from "@/components/ui/dialog/dialog.astro"

type Props = Omit<
  ComponentProps<typeof Dialog>,
  | "data-default-open"
  | "data-close-on-click-outside"
  | "data-close-on-escape"
  | "data-lock-scroll"
> & {
  defaultOpen?: boolean
  closeOnClickOutside?: boolean
  closeOnEscape?: boolean
  lockScroll?: boolean
}

const {
  class: className,
  defaultOpen,
  closeOnClickOutside,
  closeOnEscape,
  lockScroll,
  ...props
} = Astro.props
---

<Dialog
  class={className}
  data-default-open={defaultOpen}
  data-close-on-click-outside={closeOnClickOutside}
  data-close-on-escape={closeOnEscape}
  data-lock-scroll={lockScroll}
  {...props}
>
  <slot />
</Dialog>
