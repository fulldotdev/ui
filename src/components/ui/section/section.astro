---
import type { HTMLAttributes } from "astro/types"
import { cva, type VariantProps } from "class-variance-authority"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"section"> & VariantProps<typeof variants>

const variants = cva("relative flex scroll-mt-12 flex-col gap-16 py-16", {
  variants: {
    variant: {
      default: "bg-background w-full",
      floating:
        "bg-background mx-auto my-16 w-[calc(100%-2rem)] max-w-[calc(var(--container,1280px)-2rem)] overflow-hidden rounded-xl border shadow-md",
    },
  },
  defaultVariants: {
    variant: "default",
  },
})

const { class: className, variant, ...props } = Astro.props
---

<section
  class={cn(variants({ variant }), className)}
  data-slot="section"
  data-variant={variant}
  {...props}
>
  <slot />
</section>
