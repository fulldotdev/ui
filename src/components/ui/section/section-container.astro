---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"div">

const { class: className, ...props } = Astro.props
---

<div
  class={cn(
    "relative mx-auto flex w-full max-w-7xl flex-col gap-8 px-4",
    className
  )}
  {...props}
>
  <slot />
</div>
