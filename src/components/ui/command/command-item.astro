---
import { CheckIcon } from "@lucide/astro"
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"div"> & {
  disabled?: boolean
  value?: string
  label?: string
  keywords?: string | string[]
  forceMount?: boolean
}

const {
  class: className,
  disabled,
  value,
  label,
  keywords,
  forceMount,
  ...props
} = Astro.props

const keywordsValue = Array.isArray(keywords) ? keywords.join(", ") : keywords
---

<div
  data-slot="command-item"
  data-disabled={disabled ? "true" : undefined}
  data-value={value}
  data-label={label}
  data-keywords={keywordsValue}
  data-force-mount={forceMount ? "true" : undefined}
  class={cn(
    "group/command-item relative flex cursor-default items-center gap-2 rounded-sm px-2 py-1.5 text-sm outline-hidden select-none in-data-[slot=dialog-content]:rounded-lg! data-selected:bg-muted data-selected:text-foreground [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 data-selected:**:[svg]:text-foreground data-[disabled=true]:pointer-events-none data-[disabled=true]:opacity-50",
    className
  )}
  {...props}
>
  <slot />
  <CheckIcon class="ml-auto opacity-0 group-has-data-[slot=command-shortcut]/command-item:hidden group-data-[checked=true]/command-item:opacity-100" />
</div>
