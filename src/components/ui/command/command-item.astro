---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

interface Props extends HTMLAttributes<"div"> {
  disabled?: boolean
  value?: string
  label?: string
  keywords?: string | string[]
  forceMount?: boolean
}

const {
  class: className,
  disabled,
  value,
  label,
  keywords,
  forceMount,
  ...props
} = Astro.props

const keywordsValue = Array.isArray(keywords) ? keywords.join(", ") : keywords
---

<div
  data-slot="command-item"
  data-disabled={disabled ? "true" : undefined}
  data-value={value}
  data-label={label}
  data-keywords={keywordsValue}
  data-force-mount={forceMount ? "true" : undefined}
  class={cn(
    "group/command-item relative flex cursor-default items-center gap-2 rounded-sm px-2 py-1.5 text-sm outline-hidden select-none data-[disabled=true]:pointer-events-none data-[disabled=true]:opacity-50 data-selected:bg-accent data-selected:text-accent-foreground hover:bg-accent hover:text-accent-foreground [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 data-selected:**:[svg]:text-accent-foreground [&_svg:not([class*='text-'])]:text-muted-foreground",
    className
  )}
  {...props}
>
  <slot />
</div>
