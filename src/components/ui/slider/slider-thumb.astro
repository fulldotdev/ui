---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"div"> & {
  label?: string
}

const { class: className, label, ...props } = Astro.props
---

<div
  data-slot="slider-thumb"
  data-label={label}
  class={cn(
    "border-primary ring-ring/50 block size-4 shrink-0 rounded-full border bg-white shadow-sm transition-[color,box-shadow] select-none hover:ring-4 focus-visible:ring-4 focus-visible:outline-hidden data-[disabled]:pointer-events-none data-[disabled]:opacity-50 data-[dragging]:shadow-md",
    className
  )}
  {...props}
>
  <slot />
</div>
