---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"main">

const { class: className, ...props } = Astro.props
---

<main
  data-slot="sidebar-inset"
  class={cn(
    "bg-background relative flex w-full flex-1 flex-col md:group-data-[sidebar-shell]:rounded-xl md:group-data-[sidebar-shell]:shadow-sm md:peer-data-[variant=inset]:rounded-xl md:peer-data-[variant=inset]:shadow-sm",
    className
  )}
  {...props}
>
  <slot />
</main>
