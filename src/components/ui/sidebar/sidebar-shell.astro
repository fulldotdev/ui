---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"div">

const { class: className, ...props } = Astro.props
---

<div
  data-slot="sidebar-shell"
  data-sidebar-shell=""
  class={cn(
    "group relative flex w-full flex-1 flex-col gap-y-1 md:peer-data-[variant=inset]:m-2 md:peer-data-[variant=inset]:ml-0 md:peer-data-[variant=inset]:peer-data-[state=collapsed]:ml-2",
    className
  )}
  {...props}
>
  <slot />
</div>
