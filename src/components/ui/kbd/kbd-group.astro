---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"kbd">

const { class: className, ...props } = Astro.props
---

<kbd
  data-slot="kbd-group"
  class={cn("inline-flex items-center gap-1", className)}
  {...props}
>
  <slot />
</kbd>
