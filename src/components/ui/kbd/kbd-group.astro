---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

type Props = HTMLAttributes<"div">

const { class: className, ...props } = Astro.props
---

<div
  data-slot="kbd-group"
  class={cn("inline-flex items-center gap-1 leading-none", className)}
  {...props}
>
  <slot />
</div>
