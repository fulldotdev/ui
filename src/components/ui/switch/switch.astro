---
import type { HTMLAttributes } from "astro/types"

import { cn } from "@/lib/utils"

import { switchVariants, type SwitchVariantProps } from "./switch-variants"

type Props = HTMLAttributes<"span"> &
  Omit<SwitchVariantProps, "size"> & {
    defaultChecked?: boolean
    disabled?: boolean
    readOnly?: boolean
    required?: boolean
    name?: string
    size?: NonNullable<SwitchVariantProps["size"]>
    value?: string
    uncheckedValue?: string
  }

const {
  class: className,
  defaultChecked,
  disabled,
  readOnly,
  required,
  name,
  size = "default",
  value,
  uncheckedValue,
  ...props
} = Astro.props

const initialChecked = defaultChecked === true
---

<span
  role="switch"
  aria-checked={initialChecked ? "true" : "false"}
  aria-disabled={disabled ? "true" : undefined}
  aria-readonly={readOnly ? "true" : undefined}
  aria-required={required ? "true" : undefined}
  data-slot="switch"
  data-size={size}
  data-checked={initialChecked ? "" : undefined}
  data-unchecked={initialChecked ? undefined : ""}
  data-default-checked={defaultChecked}
  data-disabled={disabled}
  data-read-only={readOnly}
  data-readonly={readOnly}
  data-required={required}
  data-name={name}
  data-value={value}
  data-unchecked-value={uncheckedValue}
  class={cn(switchVariants({ size }), className)}
  {...props}
>
  <span
    aria-hidden="true"
    data-slot="switch-thumb"
    class="pointer-events-none block rounded-full bg-background ring-0 transition-transform group-data-[size=default]/switch:size-4 group-data-[size=sm]/switch:size-3 group-data-[size=default]/switch:data-checked:translate-x-[calc(100%-2px)] group-data-[size=sm]/switch:data-checked:translate-x-[calc(100%-2px)] dark:data-checked:bg-primary-foreground group-data-[size=default]/switch:data-unchecked:translate-x-0 group-data-[size=sm]/switch:data-unchecked:translate-x-0 dark:data-unchecked:bg-foreground"
  ></span>
</span>

<script>
  import { create } from "@data-slot/switch"

  create()
</script>
