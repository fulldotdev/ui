---
import type { HTMLAttributes } from "astro/types"
import type {
  PopoverAlign,
  PopoverSide,
} from "@data-slot/popover"

import { cn } from "@/lib/utils"

interface Props extends HTMLAttributes<"div"> {
  side?: PopoverSide
  align?: PopoverAlign
  sideOffset?: number
  alignOffset?: number
  avoidCollisions?: boolean
  collisionPadding?: number
  /** @deprecated Use `side` instead. */
  position?: PopoverSide
}

type PopoverPositionerInternalProps = Omit<Props, "position"> & {
  position?: PopoverSide
}

const {
  class: className,
  side,
  align,
  sideOffset,
  alignOffset,
  avoidCollisions,
  collisionPadding,
  position,
  ...props
} = Astro.props as PopoverPositionerInternalProps

const booleanDataAttr = (value?: boolean) =>
  value === undefined ? undefined : value ? "" : "false"
---

<div
  data-slot="popover-positioner"
  data-side={side}
  data-align={align}
  data-side-offset={sideOffset}
  data-align-offset={alignOffset}
  data-avoid-collisions={booleanDataAttr(avoidCollisions)}
  data-collision-padding={collisionPadding}
  data-position={position}
  class={cn("isolate z-50", className)}
  {...props}
>
  <slot />
</div>
