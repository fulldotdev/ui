---
import type { HTMLAttributes } from "astro/types"
import type {
  PopoverAlign,
  PopoverSide,
} from "@data-slot/popover"

interface Props extends HTMLAttributes<"div"> {
  defaultOpen?: boolean
  side?: PopoverSide
  align?: PopoverAlign
  sideOffset?: number
  alignOffset?: number
  avoidCollisions?: boolean
  collisionPadding?: number
  portal?: boolean
  /** @deprecated Use `side` instead. */
  position?: PopoverSide
  closeOnClickOutside?: boolean
  closeOnEscape?: boolean
}

type PopoverInternalProps = Omit<Props, "position"> & { position?: PopoverSide }

const {
  class: className,
  defaultOpen,
  side,
  align,
  sideOffset,
  alignOffset,
  avoidCollisions,
  collisionPadding,
  portal,
  position,
  closeOnClickOutside,
  closeOnEscape,
  ...props
} = Astro.props as PopoverInternalProps
---

<div
  data-slot="popover"
  data-default-open={defaultOpen}
  data-side={side}
  data-align={align}
  data-side-offset={sideOffset}
  data-align-offset={alignOffset}
  data-avoid-collisions={avoidCollisions}
  data-collision-padding={collisionPadding}
  data-portal={portal}
  data-position={position}
  data-close-on-click-outside={closeOnClickOutside}
  data-close-on-escape={closeOnEscape}
  class={className}
  {...props}
>
  <slot />
</div>

<script>
  import { create } from "@data-slot/popover"

  create()
</script>
