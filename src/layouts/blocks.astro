---
import Base from "@/layouts/base.astro"
import type { MarkdownHeading } from "astro"
import { getCollection, type CollectionEntry } from "astro:content"

import type { GlobalSchema } from "@/schemas/global"
import type { BlocksSchema } from "@/schemas/layouts/blocks"
import type { SeoSchema } from "@/schemas/shared"
import { hrefFromPageId } from "@/lib/pages"
import { TypographyH1, TypographyLead } from "@/components/ui/typography"

type Props = {
  global: GlobalSchema
  page: BlocksSchema
  headings: MarkdownHeading[]
}

const props: Props = Astro.props

const fallbackSeo: SeoSchema = {
  title: props.page.seo?.title ?? props.page.title,
  description:
    props.page.seo?.description ??
    props.page.description ??
    `${props.page.title} block previews for Fulldev UI.`,
  image: props.page.seo?.image,
  canonical: props.page.seo?.canonical,
  noindex: props.page.seo?.noindex,
  nofollow: props.page.seo?.nofollow,
}

const page: BlocksSchema = {
  ...props.page,
  seo: fallbackSeo,
}

const blockPages = (await getCollection("pages")).filter(
  (
    entry
  ): entry is CollectionEntry<"pages"> & {
    data: { type: "block"; title: string; description?: string }
  } => {
    return entry.data.type === "block" && entry.id.startsWith("blocks/")
  }
)

const blockCategories = blockPages
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((entry) => {
    return {
      href: hrefFromPageId(entry.id),
      title: entry.data.title,
      description: entry.data.description,
    }
  })
---

<Base
  global={props.global}
  page={page}
  headings={props.headings}
  desktopNavigation="header"
>
  <div class="mx-auto w-full px-6 pt-10 pb-10 sm:px-8 sm:pt-12 sm:pb-12">
    <div class="mx-auto flex w-full max-w-[84rem] flex-col gap-10">
      <header class="flex flex-col gap-4 border-b pb-8">
        <TypographyH1
          class="text-foreground text-left text-3xl tracking-tight sm:text-4xl"
        >
          {props.page.title}
        </TypographyH1>
        {
          props.page.description && (
            <TypographyLead class="max-w-2xl text-base leading-7">
              {props.page.description}
            </TypographyLead>
          )
        }
      </header>
      <section class="grid gap-2 md:grid-cols-2 xl:grid-cols-3">
        {
          blockCategories.map((category) => (
            <a
              href={category.href}
              class="bg-muted/40 hover:bg-muted/60 rounded-lg px-4 py-4 transition-colors"
            >
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <p class="text-sm font-medium">{category.title}</p>
                  {category.description && (
                    <p class="text-muted-foreground mt-1 text-sm leading-6">
                      {category.description}
                    </p>
                  )}
                </div>
              </div>
            </a>
          ))
        }
      </section>
    </div>
  </div>
</Base>
