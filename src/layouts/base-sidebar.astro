---
import { getCollection } from "astro:content"

import type { GlobalSchema } from "@/schemas/global"
import { Footer } from "@/components/ui/footer"
import { HeaderGroup, Header as SiteHeader } from "@/components/ui/header"
import {
  Layout,
  LayoutBody,
  LayoutHead,
  LayoutMain,
} from "@/components/ui/layout"
import {
  Sidebar,
  SidebarContent,
  SidebarFooter,
  SidebarGroup,
  SidebarGroupLabel,
  SidebarHeader,
  SidebarInset,
  SidebarMenu,
  SidebarMenuButton,
  SidebarMenuItem,
  SidebarProvider,
  SidebarSeparator,
} from "@/components/ui/sidebar"

type DocsPage = {
  id: string
  title: string
  description?: string
}

type Props = {
  global?: GlobalSchema
  page: DocsPage
  hideHeader?: boolean
  hideFooter?: boolean
}

const {
  global,
  page,
  hideHeader = false,
  hideFooter = false,
} = Astro.props as unknown as Props

const siteName = global?.name || "Fulldev UI"
const pageTitle = page.title || siteName
const pageDescription =
  page.description ||
  "Documentation for the Fulldev UI Astro component library."

const primaryNav = [
  { label: "Introduction", href: "/docs/" },
  { label: "Installation", href: "/docs/installation/" },
  { label: "Theming", href: "/docs/theming/" },
  { label: "Components", href: "/docs/components/" },
]

const docsPages = (await getCollection("pages")).filter((entry) => {
  return entry.data.type === "docs" && entry.id.startsWith("docs/components/")
}) as Array<{
  id: string
  data: {
    type: "docs"
    title: string
  }
}>

const componentNav = docsPages
  .filter((entry) => entry.id !== "docs/components")
  .map((entry) => ({
    href: `/${entry.id}/`,
    label: entry.data.title,
    isActive: entry.id === Astro.props.page.id,
  }))
  .sort((a, b) => a.label.localeCompare(b.label))
---

<Layout>
  <LayoutHead
    name={global?.name}
    title={pageTitle}
    description={pageDescription}
  />
  <LayoutBody class="font-sans">
    <SidebarProvider>
      <Sidebar variant="floating" collapsible="icon">
        <SidebarHeader>
          <div class="px-2 py-2">
            <p class="text-sidebar-foreground text-sm font-semibold">
              {siteName}
            </p>
            <p class="text-sidebar-foreground/60 mt-1 text-xs">{pageTitle}</p>
          </div>
        </SidebarHeader>
        <SidebarContent>
          <SidebarGroup>
            <SidebarGroupLabel>Navigation</SidebarGroupLabel>
            <SidebarMenu>
              {
                primaryNav.map((item) => (
                  <SidebarMenuItem>
                    <SidebarMenuButton
                      href={item.href}
                      isActive={
                        item.href === "/docs/components/"
                          ? Astro.url.pathname.startsWith("/docs/components")
                          : Astro.url.pathname === item.href
                      }
                    >
                      <span>{item.label}</span>
                    </SidebarMenuButton>
                  </SidebarMenuItem>
                ))
              }
            </SidebarMenu>
          </SidebarGroup>
          {
            componentNav.length > 0 && (
              <SidebarGroup>
                <SidebarGroupLabel>Components</SidebarGroupLabel>
                <SidebarMenu>
                  {componentNav.map((item) => (
                    <SidebarMenuItem>
                      <SidebarMenuButton
                        href={item.href}
                        isActive={item.isActive}
                      >
                        <span>{item.label}</span>
                      </SidebarMenuButton>
                    </SidebarMenuItem>
                  ))}
                </SidebarMenu>
              </SidebarGroup>
            )
          }
        </SidebarContent>
        <SidebarSeparator />
        <SidebarFooter>
          <p class="text-sidebar-foreground/60 px-2 text-xs">{siteName}</p>
        </SidebarFooter>
      </Sidebar>
      <SidebarInset>
        {
          !hideHeader && (
            <SiteHeader container="full" sticky="never">
              <HeaderGroup class="gap-3">
                <span class="text-sm font-semibold tracking-tight">
                  {pageTitle}
                </span>
              </HeaderGroup>
              <HeaderGroup side="end" class="hidden sm:flex">
                <span class="text-muted-foreground text-sm">{siteName}</span>
              </HeaderGroup>
            </SiteHeader>
          )
        }
        <LayoutMain>
          <slot />
        </LayoutMain>
        {
          !hideFooter && (
            <Footer class="gap-3 py-8">
              <div class="text-muted-foreground flex flex-col gap-2 text-sm md:flex-row md:items-center md:justify-between">
                <p class="text-foreground font-medium">{siteName}</p>
                <p>{pageTitle}</p>
              </div>
            </Footer>
          )
        }
      </SidebarInset>
    </SidebarProvider>
  </LayoutBody>
</Layout>
