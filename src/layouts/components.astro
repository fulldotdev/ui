---
import Base from "@/layouts/base.astro"
import type { MarkdownHeading } from "astro"
import { getCollection } from "astro:content"

import type { GlobalSchema } from "@/schemas/global"
import type { ComponentsSchema } from "@/schemas/layouts/components"
import { SectionContainer } from "@/components/ui/section"
import {
  Typography,
  TypographyH1,
  TypographyLead,
} from "@/components/ui/typography"

type Props = {
  global: GlobalSchema
  page: ComponentsSchema
  headings: MarkdownHeading[]
}

const props: Props = Astro.props

const componentPages = (
  await getCollection("pages", ({ data, id }) => {
    return (
      data.type === "doc" &&
      id.startsWith("docs/components/") &&
      id !== "docs/components"
    )
  })
)
  .map((entry) => ({
    href: `/${entry.id}/`,
    title: entry.data.title,
    description: entry.data.description,
  }))
  .sort((a, b) => a.title.localeCompare(b.title))
---

<Base global={props.global} page={props.page} desktopNavigation="sidebar">
  <SectionContainer class="gap-10 pt-10 pb-8 sm:pt-12 sm:pb-10">
    <div class="mx-auto flex w-full max-w-3xl min-w-0 flex-col gap-10">
      <header class="flex min-w-0 flex-col gap-2">
        <TypographyH1
          class="text-foreground text-left text-3xl tracking-tight sm:text-4xl"
        >
          {props.page.title}
        </TypographyH1>
        {
          props.page.description && (
            <TypographyLead class="max-w-2xl text-base leading-7">
              {props.page.description}
            </TypographyLead>
          )
        }
      </header>

      <Typography as="article">
        <slot />
      </Typography>

      <section class="grid gap-2 md:grid-cols-2">
        {
          componentPages.map((item) => (
            <a
              href={item.href}
              class="bg-muted/30 hover:bg-muted/60 focus-visible:ring-ring/50 rounded-lg px-4 py-4 transition-colors focus-visible:ring-2 focus-visible:outline-none"
            >
              <span class="text-sm font-medium">{item.title}</span>
              {item.description && (
                <span class="text-muted-foreground block text-sm leading-6">
                  {item.description}
                </span>
              )}
            </a>
          ))
        }
      </section>
    </div>
  </SectionContainer>
</Base>
