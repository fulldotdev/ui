---
import Base from "@/layouts/base.astro"
import {
  BlocksIcon,
  CodeIcon,
  FileTextIcon,
  LayoutGridIcon,
  PaletteIcon,
  SignpostIcon,
} from "@lucide/astro"
import type { MarkdownHeading } from "astro"

import type { GlobalSchema } from "@/schemas/global"
import type { HomeSchema } from "@/schemas/layouts/home"
import CallToActionBlock from "@/components/blocks/cta-1.astro"
import FaqBlock from "@/components/blocks/faqs-1.astro"
import IconFeatureGridBlock from "@/components/blocks/features-2.astro"
import SiteFooterBlock from "@/components/blocks/footer-1.astro"
import HomeHeroBlock from "@/components/blocks/hero-1.astro"
import LinkedTileGridBlock from "@/components/blocks/links-2.astro"

type Props = {
  global: GlobalSchema
  page: HomeSchema
  headings: MarkdownHeading[]
}

type ActionVariant = "default" | "outline" | "ghost" | "secondary"

const props: Props = Astro.props

const heroActions = props.page.hero.buttons.map((button, index) => ({
  href: button.href,
  label: button.text,
  variant: (index === 0 ? "default" : "outline") as ActionVariant,
}))

const categoryItems = [
  {
    icon: LayoutGridIcon,
    title: "Layout",
    description:
      "Section, Separator, and Layout components to structure your content with flexible, responsive layout primitives.",
  },
  {
    icon: SignpostIcon,
    title: "Navigation",
    description:
      "Header, Sidebar, Breadcrumb, Tabs, and Navigation Menu to guide visitors through your content.",
  },
  {
    icon: BlocksIcon,
    title: "Content Display",
    description:
      "Card, Accordion, Badge, and Table to present articles, features, and structured information.",
  },
  {
    icon: PaletteIcon,
    title: "Theming",
    description:
      "Built-in dark mode, theme toggle, and CSS variables for complete control over your site's visual identity.",
  },
  {
    icon: FileTextIcon,
    title: "Forms & Input",
    description:
      "Input, Select, Checkbox, Switch, Radio Group, and Field components for accessible, styled forms.",
  },
  {
    icon: CodeIcon,
    title: "Shadcn Compatible",
    description:
      "Uses the same API conventions as shadcn/ui, so AI tools and developers can work with it immediately.",
  },
]

const browseItems = [
  {
    href: "/docs/components/section",
    title: "Section",
    description:
      "Organize page content into semantic, styled sections with flexible padding and layout options.",
    preview: "section" as const,
  },
  {
    href: "/docs/components/card",
    title: "Card",
    description:
      "Display content in a contained, elevated surface with header, body, and footer slots.",
    preview: "card" as const,
  },
  {
    href: "/docs/components/accordion",
    title: "Accordion",
    description:
      "Collapse and expand content sections with smooth animations and keyboard support.",
    preview: "accordion" as const,
  },
  {
    href: "/docs/components/tabs",
    title: "Tabs",
    description:
      "Switch between different views of content with accessible, animated tab panels.",
    preview: "tabs" as const,
  },
  {
    href: "/docs/components/header",
    title: "Header",
    description:
      "Full-featured site header with navigation, mobile menu, and inset layout support.",
    preview: "header" as const,
  },
  {
    href: "/docs/components/button",
    title: "Button",
    description:
      "Versatile button with multiple variants, sizes, and polymorphic rendering support.",
    preview: "button" as const,
  },
]

const faqItems = [
  {
    id: "faq-1",
    question: "What is Fulldev UI?",
    answer:
      "Fulldev UI is a free and open-source set of components built exclusively for Astro. It provides beautifully designed, accessible components with zero framework dependencies — everything runs as vanilla Astro components with no React, Vue, or Svelte required.",
  },
  {
    id: "faq-2",
    question: "Is it compatible with shadcn/ui?",
    answer:
      "Yes. Fulldev UI uses the same API conventions and naming patterns as shadcn/ui. This means AI coding tools and developers already familiar with shadcn/ui can work with Fulldev UI right away without learning new patterns.",
  },
  {
    id: "faq-3",
    question: "How do I install components?",
    answer:
      "Install components individually using the shadcn CLI. For example, run npx shadcn@latest add @fulldev/button to add the Button component. Each component is self-contained and includes all its dependencies.",
  },
  {
    id: "faq-4",
    question: "Does it require a JavaScript framework?",
    answer:
      "No. Every component is built with vanilla Astro and ships zero client-side JavaScript by default. Interactive components like Tabs and Accordion use minimal, targeted scripts that are automatically loaded only when needed.",
  },
  {
    id: "faq-5",
    question: "Can I customize the design?",
    answer:
      "Absolutely. Components use CSS variables and Tailwind CSS for styling, giving you full control over colors, spacing, typography, and dark mode. You own the source code and can modify any component to match your brand.",
  },
]

const ctaActions = props.page.cta.buttons.map((button, index) => ({
  href: button.href,
  label: button.text,
  variant: (index === 0 ? "default" : "outline") as ActionVariant,
}))
---

<Base
  global={props.global}
  page={props.page}
  headings={props.headings}
  desktopNavigation="header"
>
  <HomeHeroBlock
    props={{
      title: props.page.hero.title,
      description: props.page.hero.description,
      actions: heroActions,
      preview: {
        left: {
          searchPlaceholder: "Search components...",
          alert: {
            title: "New in v0.9",
            description: "ThemeToggle and Slider components now available.",
          },
          quickActions: [
            { label: "Get started", href: "/docs/", variant: "default" },
            {
              label: "Documentation",
              href: "/docs/components/",
              variant: "outline",
            },
            {
              label: "GitHub",
              href: "https://github.com/fulldotdev/ui",
              variant: "ghost",
            },
          ],
          select: {
            placeholder: "Select a framework",
            options: [
              { value: "astro", label: "Astro" },
              { value: "react", label: "React" },
              { value: "vue", label: "Vue" },
              { value: "svelte", label: "Svelte" },
            ],
          },
          formattingLabels: {
            bold: "Bold",
            italic: "Italic",
            underline: "Underline",
          },
          brightness: {
            label: "Brightness",
            value: "72",
            sliderValue: 72,
          },
          toggles: [
            { label: "Email notifications", checked: true },
            { label: "Weekly digest", checked: false },
          ],
          testimonial: {
            rating: 5,
            quote: "\"Finally, Astro components designed for Astro, not ported to it.\"",
            initials: "JD",
            name: "Jamie Davis",
            role: "Sr. Developer",
          },
          ratingSummary: {
            value: 5,
            label: "4.9 · 2,400+ developers",
          },
        },
        right: {
          breadcrumb: {
            home: "Docs",
            section: "Components",
            current: "Button",
          },
          accountMenu: {
            triggerLabel: "Open menu",
            title: "My Account",
            profile: { label: "Profile", shortcut: "⇧⌘P" },
            billing: { label: "Billing", shortcut: "⌘B" },
            logout: "Log out",
          },
          audienceOptions: [
            {
              value: "solo",
              title: "Solo",
              description: "For freelancers and individual builders.",
            },
            {
              value: "team",
              title: "Team",
              description: "Collaboration and shared workspaces.",
            },
          ],
          processingLabel: "Processing...",
          badgeLabels: {
            default: "Default",
            secondary: "Pro",
            outline: "New",
            destructive: "Beta",
          },
          faq: {
            first: {
              id: "demo-1",
              question: "Is it accessible?",
              answer: "Yes. Full WAI-ARIA support with keyboard navigation.",
            },
            second: {
              id: "demo-2",
              question: "Zero JavaScript?",
              answer: "Ships zero JS by default.",
            },
          },
          workspaceCard: {
            badge: "Pro",
            title: "Team workspace",
            description:
              "Share components across projects with roles and access control.",
            action: {
              label: "Learn more",
              href: "/docs/components/card/",
              variant: "outline",
            },
          },
          contributors: {
            avatars: [
              { initials: "AK" },
              { initials: "ML" },
              { initials: "TS" },
              { initials: "RN" },
            ],
            count: "+48",
            label: "52 contributors",
          },
          emailCapture: {
            placeholder: "hello@you.dev",
            actionLabel: "Notify me",
          },
        },
      },
    }}
  />
  <IconFeatureGridBlock
    props={{
      title: "Everything you need to build content websites",
      description:
        "Over 50 components organized into clear categories, from page layout and navigation to content display and forms. Each component is built as vanilla Astro with zero framework dependencies.",
      items: categoryItems,
    }}
  />
  <LinkedTileGridBlock
    props={{
      title: "Browse the components",
      description:
        "Explore individual components with live examples, usage documentation, and installation instructions.",
      items: browseItems,
    }}
  />
  <FaqBlock
    props={{
      title: "Frequently asked questions",
      description:
        "Common questions about Fulldev UI, installation, compatibility, and how it works with Astro.",
      items: faqItems,
      defaultItem: "faq-1",
    }}
  />
  <CallToActionBlock
    props={{
      title: props.page.cta.title,
      description: props.page.cta.description,
      actions: ctaActions,
    }}
  />
  <SiteFooterBlock
    slot="footer"
    props={{
      homeHref: "/",
      name: props.global.name,
      logos: {
        dark: {
          src: props.global.logo.dark,
          alt: `${props.global.name} logo`,
        },
        light: {
          src: props.global.logo.light,
          alt: `${props.global.name} logo`,
        },
      },
      copyright: `© ${new Date().getFullYear()} ${props.global.name}`,
    }}
  />
</Base>
