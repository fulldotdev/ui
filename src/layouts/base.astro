---
import { getCollection, type CollectionEntry } from "astro:content"

import { hrefFromPageId } from "@/lib/pages"
import { Layout, LayoutBody, LayoutHead, LayoutMain } from "@/components/ui/layout"
import {
  SidebarInset,
  SidebarProvider,
  SidebarShell,
} from "@/components/ui/sidebar"
import { ThemeToggleProvider } from "@/components/ui/theme-toggle"
import Header from "@/components/blocks/header-1.astro"
import Sidebar from "@/components/blocks/sidebar-1.astro"

const { global, page, desktopNavigation } = Astro.props
const currentPath = Astro.url.pathname

const primaryNav = [
  { label: "Introduction", href: "/docs/" },
  { label: "Installation", href: "/docs/installation/" },
  { label: "Theming", href: "/docs/theming/" },
  { label: "Components", href: "/docs/components/" },
].map((item) => ({
  ...item,
  isActive:
    item.href === "/docs/components/"
      ? currentPath.startsWith("/docs/components")
      : currentPath === item.href,
}))

const componentPages = (await getCollection("pages")).filter(
  (
    entry
  ): entry is CollectionEntry<"pages"> & {
    data: { type: "doc"; title: string }
  } => {
    return entry.data.type === "doc" && entry.id.startsWith("docs/components/")
  }
)

const componentLinks = componentPages
  .filter((entry) => entry.id !== "docs/components")
  .map((entry) => ({
    label: entry.data.title,
    href: hrefFromPageId(entry.id),
    isActive: hrefFromPageId(entry.id) === currentPath,
  }))
  .sort((a, b) => a.label.localeCompare(b.label))

const navGroups = [
  {
    label: "Navigation",
    items: primaryNav,
  },
  ...(componentLinks.length > 0
    ? [
        {
          label: "Components",
          items: componentLinks,
        },
      ]
    : []),
]

const headerLinks = global.header.links.filter((link: { href: string }) => {
  return link.href === "/docs/" || link.href === "/docs/components/"
})
---

<Layout>
  <LayoutHead name={global.name} {...page.seo}>
    <ThemeToggleProvider />
  </LayoutHead>
  <LayoutBody style="--container-width: 96rem">
    <SidebarProvider
      open={desktopNavigation === "sidebar"}
      defaultOpen={desktopNavigation === "sidebar"}
    >
      <Sidebar
        state={desktopNavigation === "sidebar" ? "expanded" : "collapsed"}
        collapsible="offcanvas"
        variant="inset"
        global={global}
        navGroups={navGroups}
      />
      <SidebarShell>
        <Header
          class={desktopNavigation === "sidebar" ? "md:hidden" : ""}
          global={global}
          headerLinks={headerLinks}
        />
        <SidebarInset>
          <LayoutMain>
            <slot />
          </LayoutMain>
        </SidebarInset>
      </SidebarShell>
    </SidebarProvider>
  </LayoutBody>
</Layout>
