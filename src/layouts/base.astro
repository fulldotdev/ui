---
import type { GlobalSchema } from "@/schemas/global"
import type { BaseLayoutSchema } from "@/schemas/layouts/base"
import { Layout, LayoutBody, LayoutHead } from "@/components/ui/layout"

interface Props {
  global?: GlobalSchema
  page: BaseLayoutSchema
}

const { global, page } = Astro.props
---

<Layout>
  <LayoutHead name={global?.name} {...page.seo} />
  <LayoutBody>
    <slot />
  </LayoutBody>
</Layout>
