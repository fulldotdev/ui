---
import Docs from "@/layouts/docs.astro"
import Home from "@/layouts/home.astro"
import { getCollection, getEntry, render } from "astro:content"

export async function getStaticPaths() {
  const pages = await getCollection("pages")
  return pages.map((page) => {
    const route =
      page.id === "index"
        ? undefined
        : page.id.endsWith("/index")
          ? page.id.slice(0, -"/index".length)
          : page.id

    return {
      params: {
        page: route,
      },
      props: page,
    }
  })
}

const page = Astro.props.data
const type = page.type
const { Content } = await render(Astro.props)
const global = (await getEntry("globals", Astro.currentLocale || "en"))?.data
---

{
  type === "home" ? (
    <Home global={global} page={page}>
      <Content />
    </Home>
  ) : type === "docs" ? (
    <Docs global={global} page={{ ...page, id: Astro.props.id }}>
      <Content />
    </Docs>
  ) : null
}
