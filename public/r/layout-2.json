{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "layout-2",
  "dependencies": ["@lucide/astro"],
  "registryDependencies": [
    "@fulldev/command",
    "@fulldev/dialog",
    "@fulldev/layout",
    "@fulldev/logo",
    "@fulldev/sidebar",
    "@fulldev/theme-toggle"
  ],
  "files": [
    {
      "path": "src/components/layouts/layout-2.astro",
      "content": "---\nimport SearchIcon from \"@lucide/astro/icons/search\"\nimport type { ImageMetadata } from \"astro\"\n\nimport {\n  Command,\n  CommandDialog,\n  CommandEmpty,\n  CommandInput,\n  CommandItem,\n  CommandList,\n  CommandShortcut,\n} from \"@/components/ui/command\"\nimport { Dialog, DialogTrigger } from \"@/components/ui/dialog\"\nimport {\n  Layout,\n  LayoutBody,\n  LayoutHead,\n  LayoutMain,\n} from \"@/components/ui/layout\"\nimport { Logo, LogoImage, LogoText } from \"@/components/ui/logo\"\nimport {\n  Sidebar,\n  SidebarContent,\n  SidebarGroup,\n  SidebarGroupLabel,\n  SidebarHeader,\n  SidebarInset,\n  SidebarMenu,\n  SidebarMenuButton,\n  SidebarMenuItem,\n  SidebarProvider,\n  SidebarTrigger,\n} from \"@/components/ui/sidebar\"\nimport { ThemeProvider, ThemeToggle } from \"@/components/ui/theme-toggle\"\n\ntype Props = {\n  class?: string\n  bodyClass?: string\n  bodyStyle?: string\n  name?: string\n  title?: string\n  description?: string\n  image?: {\n    src?: ImageMetadata | string\n    alt?: string\n  }\n  noindex?: boolean\n  nofollow?: boolean\n  canonical?: string\n  logo: {\n    label: string\n    href: string\n    src?: any\n    srcLight?: any\n    srcDark?: any\n    alt?: string\n  }\n  navigation: {\n    label: string\n    href: string\n    links?: {\n      label: string\n      href: string\n    }[]\n  }[]\n  searchItems?: {\n    label: string\n    href: string\n    keywords?: string[]\n  }[]\n}\n\nconst {\n  class: className,\n  bodyClass,\n  bodyStyle = \"--container-width: 96rem\",\n  name,\n  title,\n  description,\n  image,\n  noindex,\n  nofollow,\n  canonical,\n  logo,\n  navigation,\n  searchItems = [],\n} = Astro.props\n---\n\n<Layout class={className}>\n  <LayoutHead\n    name={name}\n    title={title}\n    description={description}\n    image={image}\n    noindex={noindex}\n    nofollow={nofollow}\n    canonical={canonical}\n  >\n    <ThemeProvider />\n  </LayoutHead>\n  <LayoutBody class={bodyClass} style={bodyStyle}>\n    <SidebarProvider open defaultOpen>\n      <Sidebar collapsible=\"offcanvas\" variant=\"inset\" class=\"z-30\">\n        <SidebarHeader>\n          <div class=\"flex items-center justify-between gap-2 pl-2\">\n            <Logo href={logo.href}>\n              <LogoImage\n                src={logo.src}\n                srcLight={logo.srcLight}\n                srcDark={logo.srcDark}\n                alt={logo.alt}\n              />\n              {logo.label && <LogoText>{logo.label}</LogoText>}\n            </Logo>\n            <SidebarTrigger />\n          </div>\n          <div class=\"flex items-center gap-2\">\n            {\n              searchItems.length > 0 && (\n                <Dialog class=\"w-full\">\n                  <DialogTrigger\n                    variant=\"outline\"\n                    size=\"sm\"\n                    class=\"w-full justify-start shadow-none\"\n                  >\n                    <SearchIcon data-icon=\"inline-start\" />\n                    <span class=\"truncate\">Search</span>\n                  </DialogTrigger>\n                  <CommandDialog\n                    title=\"Search pages\"\n                    description=\"Search the site and jump to a page.\"\n                  >\n                    <Command>\n                      <CommandInput placeholder=\"Search pages...\" />\n                      <CommandList>\n                        <CommandEmpty>No results found.</CommandEmpty>\n                        {searchItems.map((item) => (\n                          <CommandItem\n                            href={item.href}\n                            value={item.href}\n                            label={item.label}\n                            keywords={item.keywords}\n                          >\n                            {item.label}\n                            <CommandShortcut>{item.href}</CommandShortcut>\n                          </CommandItem>\n                        ))}\n                      </CommandList>\n                    </Command>\n                  </CommandDialog>\n                </Dialog>\n              )\n            }\n            <ThemeToggle />\n          </div>\n        </SidebarHeader>\n        <SidebarContent>\n          {\n            navigation.map((group) => (\n              <SidebarGroup>\n                <SidebarGroupLabel>{group.label}</SidebarGroupLabel>\n                <SidebarMenu>\n                  {(group.links ?? [group]).map((item) => (\n                    <SidebarMenuItem>\n                      <SidebarMenuButton\n                        href={item.href}\n                        isActive={item.href === Astro.url.pathname}\n                      >\n                        <span>{item.label}</span>\n                      </SidebarMenuButton>\n                    </SidebarMenuItem>\n                  ))}\n                </SidebarMenu>\n              </SidebarGroup>\n            ))\n          }\n        </SidebarContent>\n      </Sidebar>\n      <SidebarInset>\n        <LayoutMain>\n          <slot />\n        </LayoutMain>\n        <slot name=\"footer\" />\n      </SidebarInset>\n    </SidebarProvider>\n  </LayoutBody>\n</Layout>\n",
      "type": "registry:block"
    }
  ],
  "type": "registry:block"
}
