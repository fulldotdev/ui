{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "products-3",
  "registryDependencies": [
    "@fulldev/init",
    "@fulldev/badge",
    "@fulldev/card",
    "@fulldev/price",
    "@fulldev/section"
  ],
  "files": [
    {
      "path": "src/components/blocks/products-3.astro",
      "content": "---\nimport { cn } from \"@/lib/utils\"\nimport { Badge } from \"@/components/ui/badge\"\nimport {\n  Card,\n  CardContent,\n  CardDescription,\n  CardHeader,\n  CardTitle,\n} from \"@/components/ui/card\"\nimport { Price, PriceValue } from \"@/components/ui/price\"\nimport { Section, SectionContainer } from \"@/components/ui/section\"\n\ntype Props = {\n  class?: string\n  badge: string\n  title: string\n  products: {\n    title: string\n    description: string\n    price: {\n      value: number\n      currency: string\n    }\n  }[]\n}\n\nconst { class: className, badge, title, products } = Astro.props\n---\n\n<Section class={cn(\"\", className)}>\n  <SectionContainer class=\"gap-8\">\n    <div class=\"mx-auto max-w-2xl text-center\">\n      <Badge variant=\"secondary\">{badge}</Badge>\n      <h2\n        class=\"mt-4 text-3xl font-semibold tracking-tight text-balance sm:text-4xl\"\n      >\n        {title}\n      </h2>\n    </div>\n    <div class=\"grid gap-4 sm:grid-cols-2 lg:grid-cols-3\">\n      {\n        products.map((product) => (\n          <Card class=\"text-center\">\n            <CardHeader>\n              <Price class=\"justify-center\">\n                <PriceValue\n                  class=\"text-3xl font-semibold\"\n                  price={product.price.value}\n                  currency={product.price.currency}\n                />\n              </Price>\n            </CardHeader>\n            <CardContent class=\"flex flex-col gap-2\">\n              <CardTitle>{product.title}</CardTitle>\n              <CardDescription>{product.description}</CardDescription>\n            </CardContent>\n          </Card>\n        ))\n      }\n    </div>\n  </SectionContainer>\n</Section>\n",
      "type": "registry:block"
    }
  ],
  "type": "registry:block"
}