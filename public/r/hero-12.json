{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "hero-12",
  "registryDependencies": [
    "@fulldev/button",
    "@fulldev/section"
  ],
  "files": [
    {
      "path": "src/components/blocks/hero-12.astro",
      "content": "---\nimport type { ImageMetadata } from \"astro\"\nimport { Image } from \"astro:assets\"\n\nimport { cn } from \"@/lib/utils\"\nimport { Button } from \"@/components/ui/button\"\nimport { Section, SectionContainer } from \"@/components/ui/section\"\n\ntype Props = {\n  class?: string\n  title: string\n  description: string\n  buttons: {\n    label: string\n    href: string\n    variant?: \"default\" | \"outline\" | \"secondary\" | \"ghost\"\n  }[]\n  image: {\n    src: ImageMetadata\n    alt: string\n  }\n}\n\nconst { class: className, title, description, buttons, image } = Astro.props\n---\n\n<Section class={cn(\"gap-8 pt-8\", className)}>\n  <SectionContainer class=\"border-y py-8\">\n    <div\n      class=\"flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between\"\n    >\n      <h1\n        class=\"text-foreground max-w-xl text-2xl leading-[1.2] font-semibold tracking-tight text-balance sm:text-3xl\"\n      >\n        {title}\n      </h1>\n      <p\n        class=\"text-muted-foreground max-w-md text-base leading-relaxed text-balance\"\n      >\n        {description}\n      </p>\n      <div class=\"flex flex-wrap gap-3\">\n        {\n          buttons.map(({ href, label, ...button }, index) => (\n            <Button\n              as=\"a\"\n              href={href}\n              variant={\n                button.variant ?? (index === 0 ? \"default\" : \"secondary\")\n              }\n              {...button}\n            >\n              {label}\n            </Button>\n          ))\n        }\n      </div>\n    </div>\n  </SectionContainer>\n  <SectionContainer>\n    <Image\n      src={image.src}\n      alt={image.alt}\n      class=\"aspect-video w-full rounded-xl border object-cover\"\n      widths={[640, 960, 1280, 1536]}\n      sizes=\"(min-width: 80rem) 80rem, 100vw\"\n      loading=\"eager\"\n    />\n  </SectionContainer>\n</Section>\n",
      "type": "registry:block"
    }
  ],
  "type": "registry:block"
}