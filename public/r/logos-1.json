{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "logos-1",
  "registryDependencies": [
    "@fulldev/init",
    "@fulldev/logo",
    "@fulldev/section"
  ],
  "files": [
    {
      "path": "src/components/blocks/logos-1.astro",
      "content": "---\nimport { cn } from \"@/lib/utils\"\nimport { Logo, LogoText } from \"@/components/ui/logo\"\nimport { Section, SectionContainer } from \"@/components/ui/section\"\n\ntype Props = {\n  class?: string\n  title: string\n  description?: string\n  brands: {\n    name: string\n    href?: string\n  }[]\n}\n\nconst { class: className, title, description, brands } = Astro.props\n---\n\n<Section class={cn(\"\", className)}>\n  <SectionContainer class=\"items-center gap-10 text-center\">\n    <div class=\"flex max-w-2xl flex-col items-center gap-4\">\n      <h2\n        class=\"text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl\"\n      >\n        {title}\n      </h2>\n      {\n        description && (\n          <p class=\"text-muted-foreground text-lg leading-relaxed text-balance\">\n            {description}\n          </p>\n        )\n      }\n    </div>\n    <div\n      class=\"text-muted-foreground flex w-full flex-wrap items-center justify-center gap-x-12 gap-y-6\"\n    >\n      {\n        brands.map((brand) => (\n          <Logo\n            class=\"hover:text-foreground grayscale transition-all hover:grayscale-0\"\n            href={brand.href}\n          >\n            <LogoText>{brand.name}</LogoText>\n          </Logo>\n        ))\n      }\n    </div>\n  </SectionContainer>\n</Section>\n",
      "type": "registry:block"
    }
  ],
  "type": "registry:block"
}