{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "faqs-2",
  "registryDependencies": [
    "@fulldev/init",
    "@fulldev/accordion",
    "@fulldev/button",
    "@fulldev/section"
  ],
  "files": [
    {
      "path": "src/components/blocks/faqs-2.astro",
      "content": "---\nimport { cn } from \"@/lib/utils\"\nimport {\n  Accordion,\n  AccordionContent,\n  AccordionItem,\n  AccordionTrigger,\n} from \"@/components/ui/accordion\"\nimport { Button } from \"@/components/ui/button\"\nimport { Section, SectionContainer } from \"@/components/ui/section\"\n\ntype Props = {\n  class?: string\n  title: string\n  description: string\n  faqs: {\n    id: string\n    question: string\n    answer: string\n  }[]\n  buttons?: {\n    label: string\n    href: string\n    variant?: \"default\" | \"outline\" | \"secondary\" | \"ghost\"\n  }[]\n}\n\nconst { class: className, title, description, faqs, buttons } = Astro.props\n---\n\n<Section class={cn(\"\", className)}>\n  <SectionContainer>\n    <div\n      class=\"grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.5fr)] lg:gap-16\"\n    >\n      <div class=\"lg:sticky lg:top-24 lg:self-start\">\n        <h2\n          class=\"text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl\"\n        >\n          {title}\n        </h2>\n        <p\n          class=\"text-muted-foreground mt-4 text-base leading-relaxed text-balance\"\n        >\n          {description}\n        </p>\n        {\n          buttons?.length && (\n            <div class=\"mt-8 flex flex-wrap gap-3\">\n              {buttons.map(({ href, label, ...button }, index) => (\n                <Button\n                  as=\"a\"\n                  href={href}\n                  size=\"lg\"\n                  variant={\n                    button.variant ?? (index === 0 ? \"default\" : \"secondary\")\n                  }\n                  {...button}\n                >\n                  {label}\n                </Button>\n              ))}\n            </div>\n          )\n        }\n      </div>\n\n      <div>\n        <Accordion collapsible>\n          {\n            faqs.map((item) => (\n              <AccordionItem value={item.id}>\n                <AccordionTrigger>{item.question}</AccordionTrigger>\n                <AccordionContent>{item.answer}</AccordionContent>\n              </AccordionItem>\n            ))\n          }\n        </Accordion>\n      </div>\n    </div>\n  </SectionContainer>\n</Section>\n",
      "type": "registry:block"
    }
  ],
  "type": "registry:block"
}