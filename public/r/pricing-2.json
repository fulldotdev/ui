{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "pricing-2",
  "dependencies": [
    "lucide-static"
  ],
  "registryDependencies": [
    "@fulldev/init",
    "@fulldev/button",
    "@fulldev/card",
    "@fulldev/price",
    "@fulldev/section",
    "@fulldev/separator"
  ],
  "files": [
    {
      "path": "src/components/blocks/pricing-2.astro",
      "content": "---\nimport CheckIcon from \"lucide-static/icons/check.svg\"\n\nimport { cn } from \"@/lib/utils\"\nimport { Button } from \"@/components/ui/button\"\nimport {\n  Card,\n  CardContent,\n  CardDescription,\n  CardFooter,\n  CardHeader,\n  CardTitle,\n} from \"@/components/ui/card\"\nimport { Price, PriceUnit, PriceValue } from \"@/components/ui/price\"\nimport { Section, SectionContainer } from \"@/components/ui/section\"\nimport { Separator } from \"@/components/ui/separator\"\n\ntype Props = {\n  class?: string\n  title: string\n  description: string\n  plans: {\n    name: string\n    description: string\n    price: number\n    compareAt?: number\n    currency: string\n    unit: string\n    features: string[]\n    button: {\n      label: string\n      href: string\n      variant?: \"default\" | \"outline\" | \"secondary\" | \"ghost\"\n    }\n  }[]\n}\n\nconst { class: className, title, description, plans } = Astro.props\n---\n\n<Section class={cn(\"\", className)}>\n  <SectionContainer class=\"gap-8\">\n    <div class=\"mx-auto max-w-2xl text-center\">\n      <h2\n        class=\"text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl\"\n      >\n        {title}\n      </h2>\n      <p\n        class=\"text-muted-foreground mt-4 text-lg leading-relaxed text-balance\"\n      >\n        {description}\n      </p>\n    </div>\n    <div\n      class=\"mx-auto grid w-full justify-center gap-6 sm:grid-cols-2 lg:grid-cols-[repeat(auto-fit,minmax(16rem,18rem))]\"\n    >\n      {\n        plans.map((plan, index) => (\n          <Card class=\"flex flex-col border-none shadow-none\">\n            <CardHeader>\n              <CardTitle>{plan.name}</CardTitle>\n              <CardDescription>{plan.description}</CardDescription>\n            </CardHeader>\n            <CardContent class=\"flex flex-col gap-6\">\n              <Price>\n                <PriceValue\n                  price={plan.price}\n                  compareAt={plan.compareAt}\n                  currency={plan.currency}\n                />\n                <PriceUnit>{plan.unit}</PriceUnit>\n              </Price>\n              <Separator />\n              <ul class=\"flex flex-col gap-3\">\n                {plan.features.map((feature) => (\n                  <li class=\"flex items-center gap-3 text-sm\">\n                    <CheckIcon class=\"text-primary size-4 shrink-0\" />\n                    {feature}\n                  </li>\n                ))}\n              </ul>\n            </CardContent>\n            <CardFooter class=\"mt-auto\">\n              <Button\n                as=\"a\"\n                href={plan.button.href}\n                variant={\n                  plan.button.variant ?? (index === 0 ? \"outline\" : \"default\")\n                }\n                class=\"w-full\"\n              >\n                {plan.button.label}\n              </Button>\n            </CardFooter>\n          </Card>\n        ))\n      }\n    </div>\n  </SectionContainer>\n</Section>\n",
      "type": "registry:block"
    }
  ],
  "type": "registry:block"
}