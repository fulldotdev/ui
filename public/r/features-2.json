{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "features-2",
  "dependencies": [
    "@lucide/astro"
  ],
  "registryDependencies": [
    "@fulldev/button",
    "@fulldev/section"
  ],
  "files": [
    {
      "path": "src/components/blocks/features-2.astro",
      "content": "---\nimport { cn } from \"@/lib/utils\"\nimport { Button } from \"@/components/ui/button\"\nimport { Icon } from \"@/components/ui/icon\"\nimport { Section, SectionContainer } from \"@/components/ui/section\"\n\ntype Props = {\n  class?: string\n  title: string\n  description: string\n  buttons?: {\n    label: string\n    href: string\n    variant?: \"default\" | \"outline\" | \"secondary\" | \"ghost\"\n  }[]\n  features: {\n    title: string\n    description: string\n    icon: string\n  }[]\n}\n\nconst { class: className, title, description, buttons, features } = Astro.props\n---\n\n<Section class={cn(\"\", className)}>\n  <SectionContainer class=\"items-center gap-6 text-center\">\n    <div class=\"flex max-w-2xl flex-col items-center gap-4\">\n      <h2\n        class=\"text-foreground text-3xl font-semibold tracking-tight text-balance sm:text-4xl\"\n      >\n        {title}\n      </h2>\n      <p\n        class=\"text-muted-foreground max-w-2xl text-lg leading-relaxed text-balance\"\n      >\n        {description}\n      </p>\n    </div>\n    {\n      buttons?.length && (\n        <div class=\"flex flex-wrap justify-center gap-3\">\n          {buttons.map(({ href, label, ...button }, index) => (\n            <Button\n              as=\"a\"\n              href={href}\n              variant={button.variant ?? (index === 0 ? \"default\" : \"outline\")}\n              {...button}\n            >\n              {label}\n            </Button>\n          ))}\n        </div>\n      )\n    }\n  </SectionContainer>\n  <SectionContainer>\n    <div\n      class=\"ring-foreground/10 bg-border grid gap-px overflow-hidden rounded-xl ring-1 ring-inset sm:grid-cols-2 lg:grid-cols-3\"\n    >\n      {\n        features.map((feature) => (\n          <div class=\"bg-background group/feature hover:bg-accent/30 relative flex flex-col items-center gap-4 p-7 text-center transition-colors\">\n            <div class=\"bg-primary/10 text-primary ring-primary/15 flex size-10 items-center justify-center rounded-lg ring-1 transition-transform ring-inset group-hover/feature:scale-105\">\n              <Icon name={feature.icon} class=\"size-5\" />\n            </div>\n            <h3 class=\"text-foreground text-base font-medium tracking-tight text-balance\">\n              {feature.title}\n            </h3>\n            <p class=\"text-muted-foreground text-sm leading-relaxed text-balance\">\n              {feature.description}\n            </p>\n          </div>\n        ))\n      }\n    </div>\n  </SectionContainer>\n</Section>\n",
      "type": "registry:block"
    }
  ],
  "type": "registry:block"
}