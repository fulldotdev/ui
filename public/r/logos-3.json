{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "logos-3",
  "registryDependencies": [
    "@fulldev/init",
    "@fulldev/logo",
    "@fulldev/section"
  ],
  "files": [
    {
      "path": "src/components/blocks/logos-3.astro",
      "content": "---\nimport { cn } from \"@/lib/utils\"\nimport { Logo, LogoText } from \"@/components/ui/logo\"\nimport { Section, SectionContainer } from \"@/components/ui/section\"\n\ntype Props = {\n  class?: string\n  brands: {\n    name: string\n    href?: string\n  }[]\n}\n\nconst { class: className, brands } = Astro.props\n---\n\n<Section class={cn(\"py-12 lg:py-16\", className)}>\n  <SectionContainer>\n    <div\n      class=\"text-muted-foreground flex flex-wrap items-center justify-center gap-x-12 gap-y-6\"\n    >\n      {\n        brands.map((brand) => (\n          <Logo\n            class=\"hover:text-foreground grayscale transition-all hover:grayscale-0\"\n            href={brand.href}\n          >\n            <LogoText>{brand.name}</LogoText>\n          </Logo>\n        ))\n      }\n    </div>\n  </SectionContainer>\n</Section>\n",
      "type": "registry:block"
    }
  ],
  "type": "registry:block"
}